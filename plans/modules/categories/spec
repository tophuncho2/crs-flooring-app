⚙️ 4. APPLICATION LAYER (Execution + Transactions)

Target location: packages/execution/src/flooring/categories/

Use Cases:

createCategoryUseCase(input: CategoryForm):
  normalizedName = domain.normalizeCategoryNameForUniqueness(input.name)
  exists = db.categoryNameExists(normalizedName)
  domain.assertCategoryNameAvailable(exists)
  record = db.createCategoryRecord(input)
  return record

updateCategoryUseCase(id: string, input: CategoryForm):
  normalizedName = domain.normalizeCategoryNameForUniqueness(input.name)
  exists = db.categoryNameExists(normalizedName, excludeId: id)
  domain.assertCategoryNameAvailable(exists)
  db.updateCategoryRecord(id, input)
  return db.getCategoryById(id)

deleteCategoryUseCase(id: string):
  deleteState = db.getCategoryDeleteState(id)
  if not found → throw CategoryExecutionError({ code: "CATEGORY_NOT_FOUND", status: 404 })

  if domain.isCategoryDeleteBlocked(deleteState):
    throw CategoryExecutionError({
      code: "CATEGORY_IN_USE",
      message: domain.getCategoryDeleteBlockedMessage(deleteState),
      status: 409,
    })

  db.deleteCategoryRecord(id)
  return { ok: true }

