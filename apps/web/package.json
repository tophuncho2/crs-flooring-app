{
  "name": "@builders/web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "node ../../run-with-root-env.mjs ../../node_modules/next/dist/bin/next dev",
    "build": "node ../../run-with-root-env.mjs ../../node_modules/next/dist/bin/next build --webpack",
    "start": "node ../../run-with-root-env.mjs ../../node_modules/next/dist/bin/next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "node ../../run-with-root-env.mjs ../../node_modules/next/dist/bin/next typegen && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@builders/db": "file:../../packages/db",
    "@builders/domain": "file:../../packages/domain",
    "@builders/application": "file:../../packages/application",
    "@builders/lib": "file:../../packages/lib",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.47.0",
    "@tanstack/react-query": "^5.0.0",
    "bcrypt": "^6.0.0",
    "lucide-react": "^0.575.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "nuqs": "^2.0.0",
    "puppeteer": "^24.37.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
