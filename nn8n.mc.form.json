            {
              "fieldLabel": "materials",
              "fieldType": "html",
              "html": "<div class=\"crs-materials\"><p class=\"crs-mat-help\">Add each product on its own row. Use “+ Add item” for as many as you need.</p><table class=\"crs-mat-table\"><thead><tr><th>Product</th><th>Qty</th><th>UOM</th><th>Notes</th><th></th></tr></thead><tbody id=\"crsMatBody\"></tbody></table><button type=\"button\" id=\"crsMatAdd\" class=\"crs-mat-add\">+ Add item</button><input type=\"hidden\" name=\"materialItems\" id=\"crsMaterialItems\"></div><script>(function(){var body=document.getElementById(\"crsMatBody\");var hidden=document.getElementById(\"crsMaterialItems\");function sync(){var data=[];body.querySelectorAll(\"tr\").forEach(function(r){var i=r.querySelectorAll(\"input\");var o={product:i[0].value.trim(),qty:i[1].value.trim(),uom:i[2].value.trim(),notes:i[3].value.trim()};if(o.product||o.qty||o.uom||o.notes){data.push(o);}});hidden.value=JSON.stringify(data);}function addRow(){var tr=document.createElement(\"tr\");[\"Product\",\"Qty\",\"UOM\",\"Notes\"].forEach(function(ph){var td=document.createElement(\"td\");var inp=document.createElement(\"input\");inp.type=\"text\";inp.placeholder=ph;inp.addEventListener(\"input\",sync);td.appendChild(inp);tr.appendChild(td);});var rtd=document.createElement(\"td\");var btn=document.createElement(\"button\");btn.type=\"button\";btn.className=\"crs-mat-rm\";btn.setAttribute(\"aria-label\",\"Remove row\");btn.textContent=\"×\";btn.addEventListener(\"click\",function(){tr.remove();sync();});rtd.appendChild(btn);tr.appendChild(rtd);body.appendChild(tr);sync();}document.getElementById(\"crsMatAdd\").addEventListener(\"click\",addRow);addRow();})();</script>"
            }
