generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  CONTRACTOR
  ADMIN
  BUILDER
}
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(CONTRACTOR)
  createdAt DateTime @default(now())
}