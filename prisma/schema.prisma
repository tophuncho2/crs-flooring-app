generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CONTRACTOR
  CUSTOMER
  ADMIN
  BUILDER
}

model User {
  id         String              @id @default(uuid())
  email      String              @unique
  password   String
  role       Role                @default(CUSTOMER)
  isVerified Boolean             @default(true)
  createdAt  DateTime            @default(now())
  toolAccesses UserToolAccess[]
  activities UserLoginActivity[]
}

model Tool {
  id                String             @id @default(uuid())
  slug              String             @unique
  name              String
  description       String
  path              String
  monthlyPriceCents Int                @default(0)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userAccesses      UserToolAccess[]

  @@index([slug])
}

model UserToolAccess {
  id            String    @id @default(uuid())
  userId        String
  toolId        String
  isActive      Boolean   @default(true)
  activatedAt   DateTime  @default(now())
  deactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool          Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@index([userId])
  @@index([toolId])
}

model UserLoginActivity {
  id         String   @id @default(uuid())
  userId     String?
  userEmail  String
  loggedInAt DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([loggedInAt])
  @@index([userEmail])
}

model Category {
  id           String    @id @default(uuid())
  name         String    @unique
  stockUnit    String
  purchaseUnit String
  coverageUnit String
  rateUnit     String
  altUnit      String?
  createdAt    DateTime  @default(now())
  products     Product[]
}

model Product {
  id              String         @id @default(uuid())
  name            String
  description     String?
  categoryId      String
  category        Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  internalCost    Decimal        @db.Decimal(10, 2)
  customerCost    Decimal        @db.Decimal(10, 2)
  laborRate       Decimal        @db.Decimal(10, 2)
  coveragePerUnit Decimal        @db.Decimal(10, 4)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())

  @@index([categoryId])
}

model Hotkey {
  id          String   @id @default(uuid())
  key         String
  combination String
  action      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum FlooringWorkOrderStatus {
  BUILDING_ORDER
  PENDING_EXPORT
  CARPET_CLEANING
  SENT_OUT
  COMPLETE
  PENDING
  PULL_TEMPLATE
  MODIFY
}

enum FlooringVacancyStatus {
  VACANT
  OCCUPIED
}

enum FlooringChangeOrderStatus {
  SHORTAGE
  SUFFICIENT
}

enum FlooringStoreCode {
  DARBY
  COLUMBIA
}

enum ConstructionJobStatus {
  FLAGGED
  PENDING_JOB
  ACTIVE_CONTRACTS
  AWAITING_PAYMENT
  PENDING_INVOICED
  OVERHEAD_2026
  COMPLETED
}

enum ConstructionJobType {
  CONSTRUCTION
  OVERHEAD_COST
}

enum ConstructionScopeType {
  MATERIAL
  LABOR
  DEPOSIT
  RENTAL
  PLANNING
  FINAL_DEPOSIT
}

enum ConstructionPendingPaymentStatus {
  PENDING_PAYMENT
  COMPLETE
}

enum ConstructionDepositType {
  FIRST_DEPOSIT
  SECOND_DEPOSIT
  THIRD_DEPOSIT
  FINAL_PAY
}

enum ConstructionReceiptApprovalStatus {
  APPROVED
  DENIED
  PENDING
  CONFIRM_PRICE
  FLAG
}

enum ConstructionVendorType {
  CRS
  LABOR_VENDOR
  MATERIAL_VENDOR
  JOB_VENDOR
  RENTAL_VENDOR
  PLATFORM
}

model PropertyHub {
  id               String                       @id @default(uuid())
  name             String
  streetAddress    String?
  city             String?
  state            String?
  postalCode       String?
  phone            String?
  email            String?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  flooringLinks    FlooringPropertyManagement[]
  flooringOrders   FlooringWorkOrder[]
  flooringTpls     FlooringTemplate[]
  constructionJobs ConstructionJob[]
  vendorLinks      ConstructionVendorProperty[]

  @@index([name])
  @@map("property_hub")
}

model FlooringManagementCompany {
  id            String                       @id @default(uuid())
  name          String                       @unique
  streetAddress String?
  city          String?
  state         String?
  postalCode    String?
  phone         String?
  email         String?
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  properties    FlooringPropertyManagement[]

  @@map("flooring_management_company")
}

model FlooringPropertyManagement {
  propertyId          String
  managementCompanyId String
  property            PropertyHub               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  managementCompany   FlooringManagementCompany @relation(fields: [managementCompanyId], references: [id], onDelete: Cascade)

  @@id([propertyId, managementCompanyId])
  @@unique([propertyId])
  @@map("flooring_property_management")
}

model FlooringCategory {
  id                    String            @id @default(uuid())
  name                  String            @unique
  categoryCode          Int?
  sendUnit              String?
  stockUnit             String?
  coverageAvailableUnit String?
  itemCoverageUnit      String?
  products              FlooringProduct[]
  createdAt             DateTime          @default(now())

  @@map("flooring_category")
}

model FlooringManufacturer {
  id         String            @id @default(uuid())
  name       String            @unique
  website    String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  products   FlooringProduct[]

  @@map("flooring_manufacturer")
}

model FlooringProduct {
  id               String                  @id @default(uuid())
  name             String                  @default("")
  categoryId       String?
  category         FlooringCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  manufacturerName String?                @map("manufacturer")
  manufacturerId   String?
  manufacturer     FlooringManufacturer?   @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  style            String?
  color            String?
  width            String?
  sheetSize        String?
  thickness        String?
  unitWeight       String?
  baseColor        String?
  coveragePerUnit  Decimal?                @db.Decimal(12, 4)
  cost             Decimal?                @db.Decimal(10, 2)
  isPublic         Boolean                 @default(false)
  notes            String?
  subOrder         String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  templateItems    FlooringTemplateItem[]
  workOrderItems   FlooringWorkOrderItem[]
  FlooringTemplate FlooringTemplate[]
  inventories      FlooringInventory[]

  @@index([manufacturerId])
  @@index([name])
  @@map("flooring_product")
}

model FlooringInventory {
  id          String         @id @default(uuid())
  productId   String
  product     FlooringProduct @relation(fields: [productId], references: [id], onDelete: Restrict)
  itemNumber  Int
  dyeLot      Int
  locationId  String
  location    FlooringLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  stockCount  Decimal        @db.Decimal(12, 2)
  notes       String?
  cutLogs     FlooringCutLog[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([productId])
  @@index([locationId])
  @@map("flooring_inventory")
}

model FlooringCutLog {
  id              String             @id @default(uuid())
  inventoryId     String
  inventory       FlooringInventory   @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  workOrderId     String?
  workOrder       FlooringWorkOrder?  @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  workOrderItemId String?
  workOrderItem   FlooringWorkOrderItem? @relation(fields: [workOrderItemId], references: [id], onDelete: SetNull)
  quantityTaken   Decimal            @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime           @default(now())

  @@index([inventoryId])
  @@index([workOrderId])
  @@index([workOrderItemId])
  @@map("flooring_cut_log")
}

model FlooringTemplate {
  id            String                 @id @default(uuid())
  propertyId    String
  property      PropertyHub            @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  templateTag   String
  store         FlooringStoreCode?
  warehouseId   String?
  warehouse     FlooringWarehouse?     @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  instructions  String?
  templateNotes String?
  padProductId  String?
  padProduct    FlooringProduct?       @relation(fields: [padProductId], references: [id], onDelete: SetNull)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  items         FlooringTemplateItem[]
  workOrders    FlooringWorkOrder[]

  @@index([propertyId])
  @@index([warehouseId])
  @@index([templateTag])
  @@map("flooring_template")
}

model FlooringTemplateItem {
  id           String           @id @default(uuid())
  templateId   String
  template     FlooringTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  productId    String
  product      FlooringProduct  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity     Decimal          @db.Decimal(10, 2)
  notes        String?
  storedDyeLot String?
  createdAt    DateTime         @default(now())

  @@index([templateId])
  @@index([productId])
  @@map("flooring_template_item")
}

model FlooringWarehouse {
  id         String                 @id @default(uuid())
  name       String                 @unique
  address    String?
  phone      String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  sections   FlooringSection[]
  locations  FlooringLocation[]
  workOrders FlooringWorkOrder[]
  templates  FlooringTemplate[]

  @@map("flooring_warehouse")
}

model FlooringSection {
  id          String             @id @default(uuid())
  warehouseId String
  warehouse   FlooringWarehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  name        String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  locations   FlooringLocation[]

  @@unique([warehouseId, name])
  @@map("flooring_section")
}

model FlooringLocation {
  id           String                 @id @default(uuid())
  warehouseId  String
  warehouse    FlooringWarehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  sectionId    String?
  section      FlooringSection?       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  locationCode String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  inventories  FlooringInventory[]

  @@unique([warehouseId, locationCode])
  @@index([sectionId])
  @@map("flooring_location")
}

model FlooringWorkOrder {
  id              String                  @id @default(uuid())
  propertyId      String
  property        PropertyHub             @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  templateId      String?
  template        FlooringTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  warehouseId     String?
  warehouse       FlooringWarehouse?      @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  status          FlooringWorkOrderStatus
  vacancy         FlooringVacancyStatus?
  scheduledFor    DateTime?               @db.Date
  unitLabel       String?
  unitNumber      Int?
  unitType        String?
  customAddress   String?
  instructions    String?
  notes           String?
  googleDriveSlip String?
  googleDocUrl    String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  items           FlooringWorkOrderItem[]
  cutLogs         FlooringCutLog[]

  @@index([propertyId, status])
  @@index([scheduledFor])
  @@map("flooring_work_order")
}

model FlooringWorkOrderItem {
  id                String                         @id @default(uuid())
  workOrderId       String
  workOrder         FlooringWorkOrder              @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  productId         String
  product           FlooringProduct                @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity          Decimal                        @db.Decimal(10, 2)
  notes             String?
  changeOrderStatus FlooringChangeOrderStatus?
  createdAt         DateTime                       @default(now())
  cutLogs           FlooringCutLog[]

  @@index([workOrderId])
  @@index([productId])
  @@map("flooring_work_order_item")
}

model ConstructionVendor {
  id              String                             @id @default(uuid())
  companyName     String
  vendorType      ConstructionVendorType?
  phone           String?
  email           String?
  website         String?
  createdAt       DateTime                           @default(now())
  updatedAt       DateTime                           @updatedAt
  jobs            ConstructionJobVendor[]
  properties      ConstructionVendorProperty[]
  scopes          ConstructionJobScope[]
  pendingPayments ConstructionPendingPayment[]
  laborRequests   ConstructionLaborPaymentRequest[]
  expenses        ConstructionExpense[]
  agreements      ConstructionSubcontractAgreement[]
  receipts        ConstructionReceipt[]

  @@index([companyName])
  @@map("construction_vendor")
}

model ConstructionVendorProperty {
  vendorId   String
  propertyId String
  vendor     ConstructionVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  property   PropertyHub        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([vendorId, propertyId])
  @@map("construction_vendor_property")
}

model ConstructionJob {
  id                String                             @id @default(uuid())
  propertyId        String?
  property          PropertyHub?                       @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  jobTag            String?
  status            ConstructionJobStatus
  jobType           ConstructionJobType                @default(CONSTRUCTION)
  startingBudget    Decimal?                           @db.Decimal(14, 2)
  revenue           Decimal?                           @db.Decimal(14, 2)
  runningBudget     Decimal?                           @db.Decimal(14, 2)
  expenseTotal      Decimal?                           @db.Decimal(14, 2)
  pendingExpenses   Decimal?                           @db.Decimal(14, 2)
  budgetRemaining   Decimal?                           @db.Decimal(14, 2)
  anticipatedProfit Decimal?                           @db.Decimal(14, 2)
  anticipatedMargin Decimal?                           @db.Decimal(8, 4)
  currentProfit     Decimal?                           @db.Decimal(14, 2)
  currentMargin     Decimal?                           @db.Decimal(8, 4)
  finalProfit       Decimal?                           @db.Decimal(14, 2)
  finalMargin       Decimal?                           @db.Decimal(8, 4)
  onSiteContact     String?
  onSitePhone       String?
  billingInfo       String?
  docusketchUrl     String?
  fullJobFileUrl    String?
  createdAt         DateTime                           @default(now())
  updatedAt         DateTime                           @updatedAt
  scopes            ConstructionJobScope[]
  vendors           ConstructionJobVendor[]
  pendingPayments   ConstructionPendingPayment[]
  laborRequests     ConstructionLaborPaymentRequest[]
  expenses          ConstructionExpense[]
  receipts          ConstructionReceipt[]
  agreements        ConstructionSubcontractAgreement[]
  receivables       ConstructionAccountsReceivable[]
  budgetIncreases   ConstructionBudgetIncrease[]
  checklist         ConstructionChecklistItem[]

  @@index([status, jobType])
  @@index([propertyId])
  @@map("construction_job")
}

model ConstructionJobVendor {
  jobId    String
  vendorId String
  job      ConstructionJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  vendor   ConstructionVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@id([jobId, vendorId])
  @@map("construction_job_vendor")
}

model ConstructionJobScope {
  id                    String                        @id @default(uuid())
  jobId                 String
  job                   ConstructionJob               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  vendorId              String?
  vendor                ConstructionVendor?           @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  scopeName             String?
  scopeType             ConstructionScopeType?
  vacancy               Boolean?
  statusComplete        Boolean                       @default(false)
  notes                 String?
  startDate             DateTime?                     @db.Date
  endDate               DateTime?                     @db.Date
  price                 Decimal?                      @db.Decimal(14, 2)
  unitCount             Decimal?                      @db.Decimal(12, 2)
  estimatedRehabBudget  Decimal?                      @db.Decimal(14, 2)
  contractedCost        Decimal?                      @db.Decimal(14, 2)
  estimatedDurationDays Int?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  dependenciesFrom      ConstructionScopeDependency[] @relation("ScopeDependsFrom")
  dependenciesTo        ConstructionScopeDependency[] @relation("ScopeDependsTo")

  @@index([jobId])
  @@index([vendorId])
  @@map("construction_job_scope")
}

model ConstructionScopeDependency {
  scopeId          String
  dependsOnScopeId String
  scope            ConstructionJobScope @relation("ScopeDependsFrom", fields: [scopeId], references: [id], onDelete: Cascade)
  dependsOnScope   ConstructionJobScope @relation("ScopeDependsTo", fields: [dependsOnScopeId], references: [id], onDelete: Cascade)

  @@id([scopeId, dependsOnScopeId])
  @@map("construction_scope_dependency")
}

model ConstructionSubcontractAgreement {
  id              String                            @id @default(uuid())
  jobId           String
  job             ConstructionJob                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  vendorId        String
  vendor          ConstructionVendor                @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  status          String?
  agreementDate   DateTime?                         @db.Date
  fullBudget      Decimal?                          @db.Decimal(14, 2)
  printSignature  String?
  agreementUrl    String?
  createdAt       DateTime                          @default(now())
  updatedAt       DateTime                          @updatedAt
  pendingPayments ConstructionPendingPayment[]
  laborRequests   ConstructionLaborPaymentRequest[]

  @@index([jobId, vendorId])
  @@map("construction_subcontract_agreement")
}

model ConstructionPendingPayment {
  id                    String                            @id @default(uuid())
  jobId                 String
  job                   ConstructionJob                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  vendorId              String
  vendor                ConstructionVendor                @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  agreementId           String?
  agreement             ConstructionSubcontractAgreement? @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  amount                Decimal                           @db.Decimal(14, 2)
  status                ConstructionPendingPaymentStatus
  depositType           ConstructionDepositType?
  completionRequiredPct Decimal?                          @db.Decimal(6, 4)
  notes                 String?
  requestedByName       String?
  createdAt             DateTime                          @default(now())
  updatedAt             DateTime                          @updatedAt

  @@index([jobId, status])
  @@index([vendorId])
  @@map("construction_pending_payment")
}

model ConstructionLaborPaymentRequest {
  id          String                            @id @default(uuid())
  jobId       String
  job         ConstructionJob                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  vendorId    String
  vendor      ConstructionVendor                @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  agreementId String?
  agreement   ConstructionSubcontractAgreement? @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  fileStage   String?
  status      String?
  amount      Decimal?                          @db.Decimal(14, 2)
  notes       String?
  requestedOn DateTime?                         @db.Date
  createdAt   DateTime                          @default(now())
  updatedAt   DateTime                          @updatedAt

  @@index([jobId])
  @@index([vendorId])
  @@map("construction_labor_payment_request")
}

model ConstructionReceipt {
  id            String                             @id @default(uuid())
  jobId         String?
  job           ConstructionJob?                   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  vendorId      String?
  vendor        ConstructionVendor?                @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  approval      ConstructionReceiptApprovalStatus?
  confirmed     Boolean                            @default(false)
  totalCost     Decimal?                           @db.Decimal(14, 2)
  store         String?
  receiptNumber String?
  poOrJobName   String?
  purchaseDate  DateTime?                          @db.Date
  paymentMethod String?
  storeAddress  String?
  notes         String?
  createdAt     DateTime                           @default(now())
  updatedAt     DateTime                           @updatedAt
  expenses      ConstructionExpense[]

  @@index([jobId])
  @@map("construction_receipt")
}

model ConstructionExpense {
  id            String               @id @default(uuid())
  jobId         String
  job           ConstructionJob      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  vendorId      String?
  vendor        ConstructionVendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  receiptId     String?
  receipt       ConstructionReceipt? @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  amount        Decimal              @db.Decimal(14, 2)
  expenseType   String?
  paymentType   String?
  paymentDate   DateTime?            @db.Date
  receiptNumber String?
  receiptUrl    String?
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([jobId])
  @@index([vendorId])
  @@index([receiptId])
  @@map("construction_expense")
}

model ConstructionAccountsReceivable {
  id         String          @id @default(uuid())
  jobId      String
  job        ConstructionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  drawAmount Decimal         @db.Decimal(14, 2)
  createdAt  DateTime        @default(now())

  @@index([jobId])
  @@map("construction_accounts_receivable")
}

model ConstructionBudgetIncrease {
  id        String          @id @default(uuid())
  jobId     String
  job       ConstructionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  amount    Decimal         @db.Decimal(14, 2)
  status    String?
  notes     String?
  jobNumber String?
  createdAt DateTime        @default(now())

  @@index([jobId])
  @@map("construction_budget_increase")
}

model ConstructionChecklistItem {
  id            String          @id @default(uuid())
  jobId         String
  job           ConstructionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  checklistItem String
  status        Boolean         @default(false)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([jobId])
  @@map("construction_checklist_item")
}
