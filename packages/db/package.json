{
  "name": "@builders/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    }
  },
  "scripts": {
    "db:generate": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma generate",
    "db:migrate:dev": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma migrate dev --skip-seed",
    "db:deploy": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma migrate deploy",
    "db:reset": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma migrate reset --force --skip-seed",
    "db:seed": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma db seed",
    "db:studio": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma studio",
    "guard:prisma": "node scripts/guard-prisma.js",
    "build": "npm run db:generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:seed:reference-test-data": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config scripts/reference-test-data.js",
    "db:backfill:product-names": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config scripts/backfill-product-names.js",
    "db:promote-admin": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config scripts/admin-recovery.js",
    "db:upsert-owner": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config scripts/owner-recovery.js",
    "db:seed:uoms": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config scripts/seed-unit-of-measures.js",
    "db:seed:categories": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config scripts/seed-categories.js"
  },
  "prisma": {
    "seed": "node -r dotenv/config scripts/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.12.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "prisma": "^6.12.0"
  }
}
