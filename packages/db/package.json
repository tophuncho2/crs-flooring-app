{
  "name": "@builders/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./prisma": {
      "types": "./dist/generated/prisma/client.d.ts",
      "default": "./dist/generated/prisma/client.js"
    }
  },
  "scripts": {
    "db:generate": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma generate",
    "db:migrate:dev": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma migrate dev",
    "db:deploy": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma migrate deploy",
    "db:migrate:status": "XDG_CACHE_HOME=../../.cache prisma migrate status",
    "db:reset": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma migrate reset --force",
    "db:seed": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma db seed",
    "db:studio": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma studio",
    "guard:prisma": "node scripts/guard-prisma.js",
    "postinstall": "DOTENV_CONFIG_PATH=../../.env XDG_CACHE_HOME=../../.cache prisma generate",
    "build": "npm run db:generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:upsert-owner": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config scripts/owner-recovery.js",
    "db:seed:uoms": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config scripts/seed-unit-of-measures.js",
    "db:seed:categories": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config scripts/seed-categories.js",
    "db:seed:work-order-statuses": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config scripts/seed-work-order-statuses.js",
    "db:seed:properties": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config scripts/seed-properties-csv.js",
    "upload:brand-logo": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config scripts/upload-brand-logo.js"
  },
  "dependencies": {
    "@builders/domain": "file:../domain",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.0.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "pg": "^8.20.0",
    "prisma": "^7.0.0"
  }
}
