generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRank {
  DEVELOPER
  TIER_1
  TIER_2
  TIER_3
}

model User {
  id                     String                @id @default(uuid())
  name                   String                @default("")
  email                  String                @unique
  emailVerified          Boolean               @default(false)
  image                  String?
  rank                   UserRank              @default(TIER_3)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @default(now()) @updatedAt
  mutationReceipts       AppMutationReceipt[]
  sessions               Session[]
  accounts               Account[]
}

// Better Auth core tables. Field names mirror Better Auth's required schema
// exactly (it accesses them via the camelCase Prisma client). Self-hosted in our
// own Postgres — no external identity store.
model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
}

// Lean invite-only, rank-scoped provisioning. Deliberately NOT Better Auth's
// org/teams plugin — we are a single company, so its team machinery would be
// over-abstraction. An invite pre-sets the new user's rank; Google verifies
// identity on first sign-in.
model UserInvite {
  id         String    @id @default(uuid())
  email      String
  rank       UserRank
  invitedBy  String?
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
}

model AppMutationReceipt {
  id               String    @id @default(uuid())
  scope            String
  userId           String
  idempotencyKey   String
  requestHash      String
  responseStatus   Int?
  responseBodyJson Json?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?
  expiresAt        DateTime
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scope, userId, idempotencyKey])
  @@index([userId])
  @@index([expiresAt])
  @@map("app_mutation_receipt")
}

enum QueueOutboxEventStatus {
  PENDING
  PROCESSING
  DISPATCHED
  EXHAUSTED
}

enum FlooringVacancyStatus {
  VACANT
  OCCUPIED
}

enum FlooringTimeOfDay {
  AM
  PM
}

enum FlooringStagedRowStatus {
  DRAFT
  QUEUED
  IMPORTED
}

enum FlooringInventoryAdjustmentType {
  INCREASE
  DEDUCTION
}

enum FlooringPaymentDirection {
  REVENUE
  EXPENSE
}

model Entity {
  id              String                @id @default(uuid())
  entityNumber    String                @unique @default(dbgenerated("('ENT-'::text || (nextval('entity_number_seq'::regclass))::text)")) @map("entity_number")
  entityNumberInt Int?                  @default(dbgenerated("(SUBSTRING(entity_number FROM 5))::integer"))
  entity          String
  streetAddress   String?
  city            String?
  state           String?
  postalCode      String?
  phone           String?
  email           String?
  color           PaletteColor          @default(SLATE)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  createdBy       String?
  updatedBy       String?
  properties      Property[]
  entityTypes     EntityEntityType[]
  payments        FlooringPayment[]
  products        FlooringProduct[]
  imports         FlooringImportEntry[]
  templatePlannedPayments TemplatePlannedPayment[]

  // Sort-column btree backing the work-orders list sort by entity name (2-hop
  // `property.entity.entity`). Plain btree — the sort's `id` tiebreak lives on
  // FlooringWorkOrder, a different table, so a composite here would be meaningless.
  @@index([entity])
  // GIN trigram backing the entity list + picker name search (ILIKE `contains`,
  // case-insensitive). Mirrors every other search bar's identity-search index.
  @@index([entity(ops: raw("gin_trgm_ops"))], type: Gin, map: "entity_entity_trgm_idx")
  // Record-number identity: the unique PREFIX string + the generated int that
  // backs the exact-int `#` search bar and the record-view stepper's neighbor walk.
  @@index([entityNumber])
  @@index([entityNumberInt])
  @@map("entity")
}

model Property {
  id                  String                     @id @default(uuid())
  propertyNumber      String                     @unique @default(dbgenerated("('PROP-'::text || (nextval('property_hub_number_seq'::regclass))::text)")) @map("property_number")
  propertyNumberInt   Int?                       @default(dbgenerated("(SUBSTRING(property_number FROM 6))::integer"))
  entityId            String?
  entity              Entity?                    @relation(fields: [entityId], references: [id], onDelete: SetNull)
  name                String
  streetAddress       String?
  city                String?
  state               String?
  postalCode          String?
  phone               String?
  email               String?
  instructions        String?
  color               PaletteColor               @default(SLATE)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  createdBy           String?
  updatedBy           String?
  workOrders          FlooringWorkOrder[]
  templates           Template[]

  @@index([entityId])
  @@index([name])
  @@index([propertyNumber])
  @@index([propertyNumberInt])
  @@index([createdAt, id])
  @@index([updatedAt, id])
  @@map("property_hub")
}

model FlooringCategory {
  id                 String                 @id @default(uuid())
  name               String                 @unique
  products                  FlooringProduct[]
  createdAt                 DateTime                                 @default(now())
  updatedAt                 DateTime                                 @updatedAt

  @@map("flooring_category")
}

model FlooringUnitOfMeasure {
  id                         String             @id @default(uuid())
  name                       String             @unique
  abbreviation               String
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  products                   FlooringProduct[]  @relation("FlooringProductUnit")
  coverageProducts           FlooringProduct[]  @relation("FlooringProductCoverageUnit")
  inventories                FlooringInventory[] @relation("FlooringInventoryUnit")
  adjustments                FlooringInventoryAdjustment[] @relation("FlooringAdjustmentUnit")
  stagedRows                 FlooringImportStagedInventoryRow[] @relation("FlooringStagedRowUnit")
  stagedFilterRows           FlooringImportStagedInventoryFilterRow[] @relation("FlooringStagedFilterRowUnit")
  plannedProducts            TemplatePlannedProduct[] @relation("TemplatePlannedProductUnit")
  invoiceProducts            TemplateInvoiceProduct[] @relation("TemplateInvoiceProductUnit")
  workOrderItems             FlooringWorkOrderItem[] @relation("FlooringWorkOrderItemUnit")

  @@map("flooring_unit_of_measure")
}

model FlooringProduct {
  id                               String                             @id @default(uuid())
  productNumber                    String                             @unique @default(dbgenerated("('PROD-'::text || (nextval('flooring_product_number_seq'::regclass))::text)")) @map("product_number")
  productNumberInt                 Int?                               @default(dbgenerated("(SUBSTRING(product_number FROM 6))::integer"))
  name                             String                             @default("")
  categoryId                       String
  category                         FlooringCategory                   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  unitId                           String
  unit                             FlooringUnitOfMeasure              @relation("FlooringProductUnit", fields: [unitId], references: [id], onDelete: Restrict)
  entityId                         String?
  entity                           Entity?                            @relation(fields: [entityId], references: [id], onDelete: SetNull)
  style                            String?
  color                            String?
  // Non-semantic palette tag (user-assigned visual color). Distinct from the
  // free-text physical `color` above — never overload that. Edit-only: only the
  // record-view edit form sets it; create/import/worker/seed fall to SLATE.
  paletteColor                     PaletteColor                       @default(SLATE)
  coveragePerUnit                  Decimal?                           @db.Decimal(12, 4)
  // Dormant FK (2A): anchor for the future coverage/conversion feature. Schema +
  // relation only — never accepted on the wire (no form/validator/use-case/write).
  coverageUnitId                   String?
  coverageUnit                     FlooringUnitOfMeasure?             @relation("FlooringProductCoverageUnit", fields: [coverageUnitId], references: [id], onDelete: Restrict)
  productNamingAddon               String?                            @db.VarChar(80)
  createdAt                        DateTime                           @default(now())
  updatedAt                        DateTime                           @updatedAt
  createdBy                        String?
  updatedBy                        String?
  plannedProducts                        TemplatePlannedProduct[]
  invoiceProducts                        TemplateInvoiceProduct[]
  workOrderItems                         FlooringWorkOrderItem[]
  inventories                            FlooringInventory[]
  inventoryAdjustments                   FlooringInventoryAdjustment[]
  FlooringImportStagedInventoryRow       FlooringImportStagedInventoryRow[]
  FlooringImportStagedInventoryFilterRow FlooringImportStagedInventoryFilterRow[]

  @@index([entityId])
  @@index([unitId])
  @@index([coverageUnitId])
  @@index([name])
  @@index([productNumber])
  @@index([productNumberInt])
  @@index([style(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_product_style_trgm_idx")
  @@index([color(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_product_color_trgm_idx")
  @@index([productNamingAddon(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_product_productNamingAddon_trgm_idx")
  @@map("flooring_product")
}

model FlooringInventory {
  id                     String               @id @default(uuid())
  inventoryNumber        String               @unique @default(dbgenerated("('INV-'::text || (nextval('flooring_inventory_number_seq'::regclass))::text)")) @map("inventory_number")
  inventoryNumberInt     Int?                 @default(dbgenerated("(SUBSTRING(inventory_number FROM 5))::integer"))
  importEntryId          String?
  importEntry            FlooringImportEntry? @relation(fields: [importEntryId], references: [id], onDelete: Restrict)
  productId              String
  product                FlooringProduct      @relation(fields: [productId], references: [id], onDelete: Restrict)
  // Canonical unit FK (UoM epic 2B). Create-only, immutable after. Seeded from
  // the product on manual create (overridable) or from the staged row at
  // materialize. The snapshot strings below are NOT a read fallback (display
  // derives from the `unit` join) — retained only to keep the promote
  // migration/backfill scripts safe; dropped post-promote (UoM 2D).
  unitId                 String
  unit                   FlooringUnitOfMeasure @relation("FlooringInventoryUnit", fields: [unitId], references: [id], onDelete: Restrict)
  rollPrefix             String               @default("ROLL#")
  rollNumber             String?              @db.VarChar(30)
  dyeLot                 String?              @db.VarChar(30)
  note                   String?              @db.VarChar(30)
  internalNotes          String?              @db.VarChar(250)
  // Non-semantic palette tag (shared PaletteColor enum). Metadata only — never
  // participates in stock/netDeducted/ledger math. Editable post-create.
  color                  PaletteColor         @default(SLATE)
  warehouseId            String
  warehouse              FlooringWarehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  location               String?              @db.VarChar(30)
  startingStock          Decimal              @db.Decimal(12, 2)
  cost                   Decimal?             @db.Decimal(12, 2)
  freight                Decimal?             @db.Decimal(12, 2)
  netDeducted            Decimal              @default(0) @db.Decimal(12, 2)
  // STORED generated stock quantity = max(0, startingStock - netDeducted),
  // mirroring the pure domain helper `computeInventoryBalance`. Sort-only key
  // for the list view's Quantity column; the displayed value still flows from
  // that domain helper in `normalizeInventoryRow` (surfaced as `stockBalance`).
  stockQuantity          Decimal?             @default(dbgenerated("GREATEST((\"startingStock\" - \"netDeducted\"), (0)::numeric)")) @db.Decimal(12, 2)
  isArchived             Boolean              @default(false)
  inventoryAdjustments   FlooringInventoryAdjustment[]
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  createdBy              String?
  updatedBy              String?

  @@index([inventoryNumber])
  @@index([inventoryNumberInt])
  @@index([importEntryId])
  @@index([productId])
  @@index([unitId])
  @@index([warehouseId])
  @@index([isArchived])
  @@index([stockQuantity, id])
  @@index([productId, createdAt, rollNumber, id])
  // Sort-column btree indexes for the menu-only inventory list sort. Composite
  // `(col, id)` so the `id` tiebreak resolves in the same scan — createdAt/updatedAt
  // are tie-prone under bulk import/worker-materialize. `(createdAt, id)` backs the
  // default list ordering (createdAt DESC, id DESC). location is only ever sorted
  // with warehouse filtered first, so lead the composite with warehouseId.
  @@index([createdAt, id])
  @@index([warehouseId, location, id])
  @@index([updatedAt, id])
  // inventoryNumber search is an exact match on `inventoryNumberInt` (btree), so
  // the number column no longer needs a trigram index.
  @@index([rollNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_rollNumber_trgm_idx")
  @@index([dyeLot(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_dyeLot_trgm_idx")
  @@index([note(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_note_trgm_idx")
  @@index([location(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_location_trgm_idx")
  @@map("flooring_inventory")
}

model FlooringImportStagedInventoryRow {
  id            String                                 @id @default(uuid())
  importEntryId String
  importEntry   FlooringImportEntry                    @relation(fields: [importEntryId], references: [id], onDelete: Restrict)
  productId     String
  product       FlooringProduct                        @relation(fields: [productId], references: [id], onDelete: Restrict)
  // Editable unit FK (UoM epic 2B) — seeded from the product, editable while
  // DRAFT; the worker materializes it forward onto the inventory row. Nullable
  // (a half-drafted row needn't carry a unit); the importability gate blocks
  // QUEUED/import when null so the worker never nulls inventory's NOT-NULL unit.
  unitId        String?
  unit          FlooringUnitOfMeasure?                 @relation("FlooringStagedRowUnit", fields: [unitId], references: [id], onDelete: Restrict)
  rollPrefix    String                                 @default("ROLL#")
  rollNumber    String?                                @db.VarChar(30)
  dyeLot        String?                                @db.VarChar(30)
  location        String?                                @db.VarChar(30)
  startingStock   Decimal                                @db.Decimal(12, 2)
  cost            Decimal?                               @db.Decimal(12, 2)
  freight         Decimal?                               @db.Decimal(12, 2)
  status          FlooringStagedRowStatus                @default(DRAFT)
  note            String?                                @db.VarChar(30)
  createdAt       DateTime                               @default(now())
  updatedAt       DateTime                               @updatedAt

  @@index([importEntryId])
  @@index([productId])
  @@index([unitId])
  @@index([importEntryId, status])
  @@map("flooring_import_staged_inventory_row")
}

model FlooringImportStagedInventoryFilterRow {
  id                  String                             @id @default(uuid())
  importEntryId       String
  importEntry         FlooringImportEntry                @relation(fields: [importEntryId], references: [id], onDelete: Restrict)
  productId           String
  product             FlooringProduct                    @relation(fields: [productId], references: [id], onDelete: Restrict)
  // Editable unit FK (UoM epic 2B) — seeded from the product, re-seeded on
  // product-change, else preserved. Nullable; filter rows never materialize.
  unitId              String?
  unit                FlooringUnitOfMeasure?             @relation("FlooringStagedFilterRowUnit", fields: [unitId], references: [id], onDelete: Restrict)
  stockOrdered        Decimal?                           @db.Decimal(12, 2)
  createdAt           DateTime                           @default(now())
  updatedAt           DateTime                           @updatedAt

  @@index([importEntryId])
  @@index([productId])
  @@index([unitId])
  @@map("flooring_import_staged_inventory_filter_row")
}

model FlooringImportEntry {
  id                  String                             @id @default(uuid())
  importNumber        Int                                @unique @default(autoincrement())
  purchaseOrderNumber String?                            @db.VarChar(50)
  warehouseId         String
  warehouse           FlooringWarehouse                  @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  entityId            String?
  entity              Entity?                            @relation(fields: [entityId], references: [id], onDelete: SetNull)
  internalNotes       String?                            @db.VarChar(250)
  color               PaletteColor                       @default(SLATE)
  createdAt           DateTime                           @default(now())
  updatedAt           DateTime                           @updatedAt
  createdBy           String?
  updatedBy           String?
  stagedInventoryRows       FlooringImportStagedInventoryRow[]
  stagedInventoryFilterRows FlooringImportStagedInventoryFilterRow[]
  inventories               FlooringInventory[]

  @@index([createdAt])
  @@index([warehouseId])
  @@index([entityId])
  @@index([purchaseOrderNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_import_entry_purchaseOrderNumber_trgm_idx")
  @@map("flooring_import_entry")
}

model FlooringInventoryAdjustment {
  id                String                            @id @default(uuid())
  adjustmentNumber  String                            @unique @default(dbgenerated("('ADJ-'::text || (nextval('flooring_inventory_adjustment_number_seq'::regclass))::text)"))
  adjustmentNumberInt Int?                            @default(dbgenerated("(SUBSTRING(\"adjustmentNumber\" FROM 5))::integer"))
  inventoryNumberInt  Int?                            @default(dbgenerated("(SUBSTRING(\"inventoryNumber\" FROM 5))::integer"))
  inventoryId       String
  inventory         FlooringInventory                 @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  inventoryNumber   String?
  rollPrefix        String?
  rollNumber        String?                           @db.VarChar(30)
  dyeLot            String?                           @db.VarChar(30)
  inventoryNote     String?                           @db.VarChar(30)
  location          String?                           @db.VarChar(30)
  area              String?                           @db.VarChar(30)
  productId         String
  product           FlooringProduct                   @relation(fields: [productId], references: [id], onDelete: Restrict)
  // Canonical unit FK (UoM epic 2B). Stamped at create from the parent
  // inventory's unitId; immutable (ledger). Display derives from the join; the
  // snapshot strings below are NOT a read fallback — retained only to keep the
  // promote migration/backfill scripts safe; dropped post-promote (UoM 2D).
  unitId            String
  unit              FlooringUnitOfMeasure             @relation("FlooringAdjustmentUnit", fields: [unitId], references: [id], onDelete: Restrict)
  warehouseId       String
  warehouse         FlooringWarehouse                 @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  workOrderId       String?
  workOrder         FlooringWorkOrder?                @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  before                 Decimal?                          @db.Decimal(12, 2)
  quantity               Decimal                           @db.Decimal(12, 2)
  after                  Decimal?                          @db.Decimal(12, 2)
  cost                   Decimal?                          @db.Decimal(12, 3)
  freight                Decimal?                          @db.Decimal(12, 3)
  adjustmentType         FlooringInventoryAdjustmentType   @default(DEDUCTION)
  isWaste                Boolean                           @default(false)
  internalNotes          String?                           @db.VarChar(250)
  color                  PaletteColor                      @default(SLATE)
  createdAt         DateTime                          @default(now())
  updatedAt         DateTime                          @updatedAt
  createdBy         String?
  updatedBy         String?

  @@index([adjustmentNumber])
  @@index([adjustmentNumberInt])
  @@index([inventoryNumberInt])
  @@index([inventoryId])
  @@index([productId])
  @@index([unitId])
  @@index([warehouseId])
  @@index([workOrderId])
  @@index([inventoryId, adjustmentType], map: "flooring_inv_adj_hub_filter_idx")
  // Adjustments ledger list view: warehouse-filtered + createdAt/id keyset sort
  // and all-warehouses createdAt/id sort.
  @@index([warehouseId, createdAt, id])
  @@index([createdAt, id])
  // Menu-only multi-column sort: updatedAt + location each composite with id so
  // the tiebreak resolves in the same scan. createdAt rides the index above;
  // productName sort rides FlooringProduct.name.
  @@index([updatedAt, id])
  @@index([location, id])
  // Per-field identity search on the frozen snapshot columns. adj#/inv# search
  // are exact matches on the generated `adjustmentNumberInt`/`inventoryNumberInt`
  // (btree, above), so those number columns need no trigram index. roll#/dye/note
  // stay substring ILIKE — each immutable post-create, so these GIN indexes are
  // insert-only, mirroring the flooring_inventory identity trgm indexes.
  @@index([rollNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_adjustment_rollNumber_trgm_idx")
  @@index([dyeLot(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_adjustment_dyeLot_trgm_idx")
  @@index([inventoryNote(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_adjustment_inventoryNote_trgm_idx")
  @@map("flooring_inventory_adjustment")
}

model FlooringJobType {
  id               String              @id @default(uuid())
  jobTypeNumber    String              @unique @default(dbgenerated("('JT-'::text || (nextval('flooring_job_type_number_seq'::regclass))::text)")) @map("job_type_number")
  jobTypeNumberInt Int?                @default(dbgenerated("(SUBSTRING(job_type_number FROM 4))::integer"))
  name             String              @unique
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  createdBy        String?
  updatedBy        String?
  templates        Template[]
  workOrders       FlooringWorkOrder[]

  @@index([name])
  @@index([jobTypeNumber])
  @@index([jobTypeNumberInt])
  @@map("flooring_job_type")
}

// Standalone single-entry payment ledger: REVENUE (money in) / EXPENSE (money out).
// Optional, single links to a work order and an entity (both nullable; a material
// outflow links to import/inventory, never directly to a WO — so the WO link must
// stay optional). Hard edit/delete is intentional for now; immutability + reversal
// semantics arrive with the analytics slice of the epic.
model FlooringPayment {
  id               String                   @id @default(uuid())
  paymentNumber    String                   @unique @default(dbgenerated("('PAY-'::text || (nextval('flooring_payment_number_seq'::regclass))::text)"))
  paymentNumberInt Int?                     @default(dbgenerated("(SUBSTRING(\"paymentNumber\" FROM 5))::integer"))
  amount           Decimal                  @db.Decimal(12, 2) // unsigned; direction carries the sign
  direction        FlooringPaymentDirection
  color            PaletteColor             @default(SLATE) // non-semantic user palette tag (edit-only)
  paymentDate      DateTime?
  entityId         String?
  entity           Entity?                  @relation(fields: [entityId], references: [id], onDelete: SetNull)
  workOrderId      String?
  workOrder        FlooringWorkOrder?       @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  createdBy        String?
  updatedBy        String?

  @@index([paymentNumber])
  @@index([paymentNumberInt])
  @@index([amount])
  @@index([entityId])
  @@index([workOrderId])
  @@index([createdAt, id])
  @@map("flooring_payment")
}

model Template {
  id                   String                     @id @default(uuid())
  templateNumber       String                     @unique @default(dbgenerated("('TP-'::text || (nextval('template_number_seq'::regclass))::text)")) @map("template_number")
  templateNumberInt    Int?                       @default(dbgenerated("(SUBSTRING(template_number FROM 4))::integer"))
  propertyId           String?
  property             Property?                  @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  jobTypeId            String?
  jobType              FlooringJobType?           @relation(fields: [jobTypeId], references: [id], onDelete: SetNull)
  warehouseId          String?
  warehouse            FlooringWarehouse?         @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  unitType             String                     @db.VarChar(40)
  customerName         String?                    @db.VarChar(100)
  description          String?                    @db.VarChar(120)
  internalNotes        String?                    @db.VarChar(250)
  installerInstructions String?                   @db.VarChar(500)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  // Non-semantic palette tag (user-assigned visual color). Metadata-only — no
  // business logic reads it. Edit-only: the create flow never sets it, so new
  // rows fall to the default SLATE. Mirrors FlooringWorkOrder.color.
  color                PaletteColor               @default(SLATE)
  createdBy            String?
  updatedBy            String?
  plannedProducts      TemplatePlannedProduct[]
  invoiceProducts      TemplateInvoiceProduct[]
  plannedPayments      TemplatePlannedPayment[]
  invoiceItems      TemplateInvoiceItem[]
  workOrders           FlooringWorkOrder[]

  @@index([templateNumberInt])
  @@index([propertyId])
  @@index([jobTypeId])
  @@index([warehouseId])
  @@index([unitType])
  @@index([createdAt])
  @@index([updatedAt])
  // GIN trigram indexes backing the list-view per-column search bars (ILIKE
  // substring). Mirrors the FlooringWorkOrder unitType/description search indexes.
  // The btree @@index([unitType]) above stays — it serves ORDER BY unitType.
  @@index([unitType(ops: raw("gin_trgm_ops"))], type: Gin, map: "template_unitType_trgm_idx")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "template_description_trgm_idx")
  @@map("template")
}

model TemplatePlannedProduct {
  id             String           @id @default(uuid())
  templateId     String
  template       Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  productId      String
  product        FlooringProduct  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity       Decimal?         @db.Decimal(10, 2)
  unitId         String?
  unit           FlooringUnitOfMeasure? @relation("TemplatePlannedProductUnit", fields: [unitId], references: [id], onDelete: Restrict)
  notes          String?          @db.VarChar(30)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdBy      String?
  updatedBy      String?

  @@index([templateId])
  @@index([templateId, createdAt])
  @@index([productId])
  @@index([unitId])
  @@map("template_planned_product")
}

// Products placed onto a template's INVOICE. A structural mirror of
// TemplatePlannedProduct (a separate table so invoice rows can grow
// invoice-specific columns — e.g. cost — in a later pass). Byte-identical to
// planned products today; the separation is the point.
model TemplateInvoiceProduct {
  id             String                 @id @default(uuid())
  templateId     String
  template       Template               @relation(fields: [templateId], references: [id], onDelete: Cascade)
  productId      String
  product        FlooringProduct        @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity       Decimal?               @db.Decimal(10, 2)
  unitId         String?
  unit           FlooringUnitOfMeasure? @relation("TemplateInvoiceProductUnit", fields: [unitId], references: [id], onDelete: Restrict)
  notes          String?                @db.VarChar(30)
  // Invoice-only money column (the deferred divergence from planned products).
  // Money standard: Decimal(12,2), normalized at every write boundary. NULL = unset.
  cost           Decimal?               @db.Decimal(12, 2)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  createdBy      String?
  updatedBy      String?

  @@index([templateId])
  @@index([templateId, createdAt])
  @@index([productId])
  @@index([unitId])
  @@map("template_invoice_product")
}

// A planned payment on a template — the repeatable-job payment plan. Field-shape
// mirrors FlooringPayment (unsigned amount + direction carrying the sign),
// structure mirrors the template child tables (Cascade off the template, actor +
// timestamp pair). Optionally links an Entity (SetNull, like FlooringPayment); no
// row#/color yet (deferred). Reuses FlooringPaymentDirection rather than forking an enum.
model TemplatePlannedPayment {
  id           String                   @id @default(uuid())
  templateId   String
  template     Template                 @relation(fields: [templateId], references: [id], onDelete: Cascade)
  amount       Decimal                  @db.Decimal(12, 2) // unsigned; direction carries the sign
  direction    FlooringPaymentDirection
  paymentDate  DateTime?
  notes        String?                  @db.VarChar(30)
  entityId     String?
  entity       Entity?                  @relation(fields: [entityId], references: [id], onDelete: SetNull)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  createdBy    String?
  updatedBy    String?

  @@index([templateId])
  @@index([templateId, createdAt])
  @@index([entityId])
  @@map("template_planned_payment")
}

// Invoice items on a template — a structural mirror of TemplatePlannedPayment
// (own table, so the two payment plans stay independently editable). Diverges from
// the planned side by design: amount · direction · notes only — NO paymentDate and
// NO entity link (and thus no FK). Reuses FlooringPaymentDirection rather than
// forking an enum; carries the standard actor + timestamp pair.
model TemplateInvoiceItem {
  id           String                   @id @default(uuid())
  templateId   String
  template     Template                 @relation(fields: [templateId], references: [id], onDelete: Cascade)
  amount       Decimal                  @db.Decimal(12, 2) // unsigned; direction carries the sign
  direction    FlooringPaymentDirection
  notes        String?                  @db.VarChar(80)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  createdBy    String?
  updatedBy    String?

  @@index([templateId])
  @@index([templateId, createdAt])
  @@map("template_invoice_item")
}

model FlooringWarehouse {
  id                  String                             @id @default(uuid())
  warehouseNumber     String                             @unique @default(dbgenerated("('STORE-'::text || (nextval('flooring_warehouse_number_seq'::regclass))::text)")) @map("warehouse_number")
  warehouseNumberInt  Int?                               @default(dbgenerated("(SUBSTRING(warehouse_number FROM 7))::integer"))
  name                String                             @unique
  streetAddress       String?
  city                String?
  state               String?
  postalCode          String?
  phone               String?
  createdAt           DateTime                           @default(now())
  updatedAt           DateTime                           @updatedAt
  createdBy           String?
  updatedBy           String?
  imports             FlooringImportEntry[]
  inventories          FlooringInventory[]
  inventoryAdjustments FlooringInventoryAdjustment[]
  workOrders           FlooringWorkOrder[]
  templates            Template[]

  @@index([warehouseNumber])
  @@index([warehouseNumberInt])
  @@map("flooring_warehouse")
}

model FlooringWorkOrder {
  id                   String                     @id @default(uuid())
  workOrderNumber      String                     @unique @default(dbgenerated("('WO-'::text || (nextval('flooring_work_order_number_seq'::regclass))::text)")) @map("work_order_number")
  workOrderNumberInt   Int?                       @default(dbgenerated("(SUBSTRING(work_order_number FROM 4))::integer"))
  propertyId           String?
  property             Property?                  @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  templateId           String?
  template             Template?          @relation(fields: [templateId], references: [id], onDelete: SetNull)
  jobTypeId            String?
  jobType              FlooringJobType?           @relation(fields: [jobTypeId], references: [id], onDelete: SetNull)
  warehouseId          String?
  warehouse            FlooringWarehouse?         @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  vacancy              FlooringVacancyStatus?
  timeOfDay            FlooringTimeOfDay?
  color                PaletteColor               @default(SLATE)
  scheduledFor         DateTime?                  @db.Date
  unitNumber           String?                    @db.VarChar(30)
  unitType             String?                    @db.VarChar(40)
  // RETIRED: customAddress is no longer read or written by any layer — the print
  // document + record form now use the WO-owned address columns below. Column
  // kept (not dropped) so existing rows retain their value pending manual backfill.
  customAddress        String?                    @db.VarChar(200)
  // WO-owned address — snapshotted from the selected property at pick time but
  // editable + detachable thereafter. Plain nullable text, mirroring Property /
  // Entity / FlooringWarehouse (no @db.VarChar bound). This is now the sole
  // address source for the record form + the printed document.
  streetAddress        String?
  city                 String?
  state                String?
  postalCode           String?
  customerName         String?                    @db.VarChar(100)
  description          String?                    @db.VarChar(120)
  internalNotes        String?                    @db.VarChar(250)
  installerInstructions String?                   @db.VarChar(500)
  installer            String?                    @db.VarChar(100)
  purchaseOrderNumber  String?                    @db.VarChar(50)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  createdBy            String?
  updatedBy            String?
  items                FlooringWorkOrderItem[]
  inventoryAdjustments FlooringInventoryAdjustment[]
  payments             FlooringPayment[]

  @@index([workOrderNumber])
  @@index([workOrderNumberInt])
  @@index([propertyId])
  @@index([templateId])
  @@index([jobTypeId])
  @@index([warehouseId])
  @@index([scheduledFor])
  @@index([createdAt])
  @@index([updatedAt])
  // Sort-column btree for the menu-only unitType sort (the GIN-trgm index below
  // serves ILIKE search, not ORDER BY). Composite `(col, id)` resolves the `id`
  // tiebreak in the same scan.
  @@index([unitType, id])
  // GIN trigram indexes backing the list-view per-column search bars (ILIKE
  // substring). Mirrors the FlooringInventory identity-search indexes.
  @@index([unitType(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_work_order_unitType_trgm_idx")
  @@index([unitNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_work_order_unitNumber_trgm_idx")
  // workOrderNumber search is an exact match on `workOrderNumberInt` (btree), so
  // the number column no longer needs a trigram index.
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_work_order_description_trgm_idx")
  @@index([purchaseOrderNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_work_order_purchaseOrderNumber_trgm_idx")
  // WO-owned address search bars. streetAddress / city / postalCode are ILIKE
  // substring (GIN-trgm); state is an exact 2-letter `IN` match (plain btree).
  @@index([streetAddress(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_work_order_streetAddress_trgm_idx")
  @@index([city(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_work_order_city_trgm_idx")
  @@index([postalCode(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_work_order_postalCode_trgm_idx")
  @@index([state])
  @@map("flooring_work_order")
}

model FlooringWorkOrderItem {
  id                   String                      @id @default(uuid())
  workOrderId          String
  workOrder            FlooringWorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  productId            String
  product              FlooringProduct             @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity             Decimal?                    @db.Decimal(10, 2)
  unitId               String?
  unit                 FlooringUnitOfMeasure?      @relation("FlooringWorkOrderItemUnit", fields: [unitId], references: [id], onDelete: Restrict)
  notes                String?                     @db.VarChar(30)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  createdBy            String?
  updatedBy            String?

  @@index([workOrderId])
  @@index([workOrderId, createdAt])
  @@index([productId])
  @@index([unitId])
  @@map("flooring_work_order_item")
}

model QueueOutboxEvent {
  id             String                 @id @default(uuid())
  topic          String
  aggregateType  String
  aggregateId    String
  idempotencyKey String                 @unique
  payloadJson    Json
  status         QueueOutboxEventStatus @default(PENDING)
  availableAt    DateTime               @default(now())
  lockedAt       DateTime?
  lockedBy       String?
  dispatchedAt   DateTime?
  attemptCount   Int                    @default(0)
  lastError      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([status, availableAt])
  @@index([status, availableAt, lockedAt, createdAt])
  @@index([topic, status, availableAt, lockedAt, createdAt])
  @@index([aggregateType, aggregateId])
  @@map("queue_outbox_event")
}

// Shared non-semantic palette colors. User-assigned, meaningless in code — purely
// a visual tag, used across modules (entity types, work orders, …). Kept in sync
// with the domain palette value object (packages/domain/src/shared/palette.ts) and
// the UI class map (apps/web/engines/common/badges/contracts/color-palette.ts).
enum PaletteColor {
  SLATE
  RED
  AMBER
  ORANGE
  LIME
  GREEN
  TEAL
  CYAN
  BLUE
  VIOLET
  PINK
  ROSE
}

// Standalone user-managed lookup row. Mirrors FlooringJobType's canonical ET-
// numbered-record shape (sequence-backed `ET-N` string + generated int for
// exact search + stepper), plus a non-semantic palette color and actor columns.
// Self-contained — NO foreign keys this slice; linking entity types to other
// models is a later step. Duplicate `type` values are allowed (no @unique).
model FlooringEntityType {
  id                  String                  @id @default(uuid())
  entityTypeNumber    String                  @unique @default(dbgenerated("('ET-'::text || (nextval('flooring_entity_type_number_seq'::regclass))::text)")) @map("entity_type_number")
  entityTypeNumberInt Int?                    @default(dbgenerated("(SUBSTRING(entity_type_number FROM 4))::integer"))
  type                String                  @db.VarChar(30)
  color               PaletteColor            @default(SLATE)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  createdBy           String?
  updatedBy           String?
  entities            EntityEntityType[]

  @@index([type])
  @@index([entityTypeNumber])
  @@index([entityTypeNumberInt])
  @@index([type(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_entity_type_type_trgm_idx")
  @@map("flooring_entity_type")
}

// Join row linking an Entity to a FlooringEntityType (many-to-many). An entity
// may carry several types; a type may tag many entities. Explicit join (not a
// Prisma implicit m-n) to match the codebase's explicit-FK house style and leave
// room for future metadata/order. Both sides cascade-delete the link row.
model EntityEntityType {
  id           String             @id @default(uuid())
  entityId     String
  entityTypeId String
  entity       Entity             @relation(fields: [entityId], references: [id], onDelete: Cascade)
  entityType   FlooringEntityType @relation(fields: [entityTypeId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())

  @@unique([entityId, entityTypeId])
  @@index([entityTypeId])
  @@map("entity_entity_type")
}

