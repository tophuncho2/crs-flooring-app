generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CONTRACTOR
  CUSTOMER
  OWNER
  ADMIN
  BUILDER
}

model User {
  id                     String                @id @default(uuid())
  email                  String                @unique
  password               String?
  role                   Role                  @default(CUSTOMER)
  isVerified             Boolean               @default(false)
  createdAt              DateTime              @default(now())
  activities             UserLoginActivity[]
  mutationReceipts       AppMutationReceipt[]
}

model UserLoginActivity {
  id         String   @id @default(uuid())
  userId     String?
  userEmail  String
  loggedInAt DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([loggedInAt])
  @@index([userEmail])
}

model AppMutationReceipt {
  id               String    @id @default(uuid())
  scope            String
  userId           String
  idempotencyKey   String
  requestHash      String
  responseStatus   Int?
  responseBodyJson Json?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?
  expiresAt        DateTime
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scope, userId, idempotencyKey])
  @@index([userId])
  @@index([expiresAt])
  @@map("app_mutation_receipt")
}

enum QueueOutboxEventStatus {
  PENDING
  PROCESSING
  DISPATCHED
  EXHAUSTED
}

enum FlooringVacancyStatus {
  VACANT
  OCCUPIED
}

enum FlooringStagedRowStatus {
  DRAFT
  QUEUED
  IMPORTED
}

enum FlooringInventoryAdjustmentStatus {
  PENDING
  QUEUED
  FINAL
}

enum FlooringInventoryAdjustmentType {
  INCREASE
  DEDUCTION
}

enum FlooringWorkOrderItemStatus {
  IDLE
  FINALIZING
  FAILED
}

model FlooringManagementCompany {
  id            String              @id @default(uuid())
  name          String
  streetAddress String?
  city          String?
  state         String?
  postalCode    String?
  phone         String?
  email         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  properties    Property[]
  templates     FlooringTemplate[]
  workOrders    FlooringWorkOrder[]

  @@map("flooring_management_company")
}

model Property {
  id                  String                     @id @default(uuid())
  managementCompanyId String?
  managementCompany   FlooringManagementCompany? @relation(fields: [managementCompanyId], references: [id], onDelete: SetNull)
  name                String
  streetAddress       String?
  city                String?
  state               String?
  postalCode          String?
  phone               String?
  email               String?
  instructions        String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  workOrders          FlooringWorkOrder[]
  templates           FlooringTemplate[]

  @@index([managementCompanyId])
  @@index([name])
  @@map("property_hub")
}

model FlooringCategory {
  id                 String                 @id @default(uuid())
  slug               String                 @unique
  name               String                 @unique
  sendUnitId         String?
  stockUnitId        String?
  itemCoverageUnitId String?
  sendUnit           FlooringUnitOfMeasure? @relation("FlooringCategorySendUnit", fields: [sendUnitId], references: [id], onDelete: Restrict)
  stockUnit          FlooringUnitOfMeasure? @relation("FlooringCategoryStockUnit", fields: [stockUnitId], references: [id], onDelete: Restrict)
  itemCoverageUnit          FlooringUnitOfMeasure?                   @relation("FlooringCategoryItemCoverageUnit", fields: [itemCoverageUnitId], references: [id], onDelete: Restrict)
  products                  FlooringProduct[]
  stagedInventoryFilterRows FlooringImportStagedInventoryFilterRow[]
  createdAt                 DateTime                                 @default(now())
  updatedAt                 DateTime                                 @updatedAt

  @@index([sendUnitId])
  @@index([stockUnitId])
  @@index([itemCoverageUnitId])
  @@map("flooring_category")
}

model FlooringUnitOfMeasure {
  id                         String             @id @default(uuid())
  slug                       String             @unique
  name                       String             @unique
  abbreviation               String
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  sendUnitCategories         FlooringCategory[] @relation("FlooringCategorySendUnit")
  stockUnitCategories        FlooringCategory[] @relation("FlooringCategoryStockUnit")
  itemCoverageUnitCategories FlooringCategory[] @relation("FlooringCategoryItemCoverageUnit")

  @@map("flooring_unit_of_measure")
}

model FlooringManufacturer {
  id                    String                @id @default(uuid())
  companyName           String
  companyNameNormalized String                @unique
  agentName             String?
  website               String?
  phone                 String?
  email                 String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  products              FlooringProduct[]
  imports               FlooringImportEntry[]

  @@index([companyName])
  @@map("flooring_manufacturer")
}

model FlooringProduct {
  id                               String                             @id @default(uuid())
  name                             String                             @default("")
  categoryId                       String
  category                         FlooringCategory                   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  manufacturerName                 String?                            @map("manufacturer")
  manufacturerId                   String?
  manufacturer                     FlooringManufacturer?              @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  style                            String?
  color                            String?
  coveragePerUnit                  Decimal?                           @db.Decimal(12, 4)
  note                             String?                            @db.VarChar(80)
  sendUnitName                     String?
  sendUnitAbbrev                   String?
  stockUnitName                    String?
  stockUnitAbbrev                  String?
  itemCoverageUnitName             String?
  itemCoverageUnitAbbrev           String?
  createdAt                        DateTime                           @default(now())
  updatedAt                        DateTime                           @updatedAt
  templateItems                          FlooringTemplateItem[]
  workOrderItems                         FlooringWorkOrderItem[]
  inventories                            FlooringInventory[]
  inventoryAdjustments                   FlooringInventoryAdjustment[]
  FlooringImportStagedInventoryRow       FlooringImportStagedInventoryRow[]
  FlooringImportStagedInventoryFilterRow FlooringImportStagedInventoryFilterRow[]

  @@index([manufacturerId])
  @@index([name])
  @@map("flooring_product")
}

model FlooringInventory {
  id                     String               @id @default(uuid())
  inventoryNumber        String               @unique @default(dbgenerated("('INV-'::text || (nextval('flooring_inventory_number_seq'::regclass))::text)")) @map("inventory_number")
  inventoryNumberInt     Int?                 @default(dbgenerated("(SUBSTRING(inventory_number FROM 5))::integer"))
  importEntryId          String?
  importEntry            FlooringImportEntry? @relation(fields: [importEntryId], references: [id], onDelete: Restrict)
  sourceStagedRowId      String?              @unique
  sourceStagedRow        FlooringImportStagedInventoryRow? @relation(fields: [sourceStagedRowId], references: [id], onDelete: SetNull)
  importNumber           String?
  purchaseOrderNumber    String?
  productId              String
  product                FlooringProduct      @relation(fields: [productId], references: [id], onDelete: Restrict)
  categorySlug           String
  categoryName           String               @default("")
  stockUnitName          String?
  stockUnitAbbrev        String?
  itemCoverageUnitName   String?
  itemCoverageUnitAbbrev String?
  sendUnitName           String?
  sendUnitAbbrev         String?
  rollPrefix             String               @default("ROLL#")
  rollNumber             String?              @db.VarChar(30)
  dyeLot                 String?              @db.VarChar(30)
  note                   String?              @db.VarChar(30)
  internalNotes          String?              @db.VarChar(250)
  inventoryItem          String               @default("")
  warehouseId            String
  warehouse              FlooringWarehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  location               String?              @db.VarChar(30)
  startingStock          Decimal              @db.Decimal(12, 2)
  netDeducted            Decimal              @default(0) @db.Decimal(12, 2)
  coveragePerUnit        Decimal?             @db.Decimal(10, 2)
  isArchived             Boolean              @default(false)
  fifoReceivedAt         DateTime             @db.Timestamptz(6)
  inventoryAdjustments   FlooringInventoryAdjustment[]
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([inventoryNumber])
  @@index([inventoryNumberInt])
  @@index([importEntryId])
  @@index([productId])
  @@index([warehouseId])
  @@index([isArchived])
  @@index([productId, fifoReceivedAt, rollNumber, id])
  @@index([warehouseId, importNumber])
  @@index([warehouseId, purchaseOrderNumber])
  @@index([inventoryNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_inventory_number_trgm_idx")
  @@index([rollNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_rollNumber_trgm_idx")
  @@index([dyeLot(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_dyeLot_trgm_idx")
  @@index([note(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_note_trgm_idx")
  @@index([location(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_location_trgm_idx")
  @@map("flooring_inventory")
}

model FlooringImportStagedInventoryRow {
  id            String                                 @id @default(uuid())
  importEntryId String
  importEntry   FlooringImportEntry                    @relation(fields: [importEntryId], references: [id], onDelete: Restrict)
  filterRowId   String
  filterRow     FlooringImportStagedInventoryFilterRow @relation(fields: [filterRowId], references: [id], onDelete: Restrict)
  productId     String
  product       FlooringProduct                        @relation(fields: [productId], references: [id], onDelete: Restrict)
  rollPrefix    String                                 @default("ROLL#")
  rollNumber    String?                                @db.VarChar(30)
  dyeLot        String?                                @db.VarChar(30)
  warehouseId   String
  warehouse     FlooringWarehouse                      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  location        String?                                @db.VarChar(30)
  startingStock   Decimal                                @db.Decimal(12, 2)
  stockUnitName   String?
  stockUnitAbbrev String?
  isImported      Boolean                                @default(false)
  status          FlooringStagedRowStatus                @default(DRAFT)
  note            String?                                @db.VarChar(30)
  createdAt       DateTime                               @default(now())
  updatedAt       DateTime                               @updatedAt
  inventoryRow    FlooringInventory?

  @@index([importEntryId])
  @@index([filterRowId])
  @@index([filterRowId, status])
  @@index([productId])
  @@index([warehouseId])
  @@index([importEntryId, isImported])
  @@index([importEntryId, status])
  @@index([status, isImported])
  @@map("flooring_import_staged_inventory_row")
}

model FlooringImportStagedInventoryFilterRow {
  id                  String                             @id @default(uuid())
  importEntryId       String
  importEntry         FlooringImportEntry                @relation(fields: [importEntryId], references: [id], onDelete: Restrict)
  categoryFilterId    String?
  categoryFilter      FlooringCategory?                  @relation(fields: [categoryFilterId], references: [id], onDelete: Restrict)
  productId           String
  product             FlooringProduct                    @relation(fields: [productId], references: [id], onDelete: Restrict)
  stockOrdered        Decimal                            @db.Decimal(12, 2)
  stockUnitName       String?
  stockUnitAbbrev     String?
  createdAt           DateTime                           @default(now())
  updatedAt           DateTime                           @updatedAt
  stagedInventoryRows FlooringImportStagedInventoryRow[]

  @@unique([importEntryId, productId])
  @@index([importEntryId])
  @@index([productId])
  @@index([categoryFilterId])
  @@map("flooring_import_staged_inventory_filter_row")
}

model FlooringImportEntry {
  id                  String                             @id @default(uuid())
  importNumber        Int                                @unique @default(autoincrement())
  purchaseOrderNumber String?                            @db.VarChar(50)
  warehouseId         String
  warehouse           FlooringWarehouse                  @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  manufacturerId      String?
  manufacturer        FlooringManufacturer?              @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  internalNotes       String?                            @db.VarChar(250)
  createdAt           DateTime                           @default(now())
  updatedAt           DateTime                           @updatedAt
  stagedInventoryRows       FlooringImportStagedInventoryRow[]
  stagedInventoryFilterRows FlooringImportStagedInventoryFilterRow[]
  inventories               FlooringInventory[]

  @@index([createdAt])
  @@index([warehouseId])
  @@index([manufacturerId])
  @@index([purchaseOrderNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_import_entry_purchaseOrderNumber_trgm_idx")
  @@map("flooring_import_entry")
}

model FlooringInventoryAdjustment {
  id                String                            @id @default(uuid())
  adjustmentNumber  String                            @unique @default(dbgenerated("('ADJ-'::text || (nextval('flooring_inventory_adjustment_number_seq'::regclass))::text)"))
  inventoryId       String
  inventory         FlooringInventory                 @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  inventoryItem     String                            @default("")
  inventoryNumber   String?
  rollPrefix        String?
  rollNumber        String?                           @db.VarChar(30)
  dyeLot            String?                           @db.VarChar(30)
  inventoryNote     String?                           @db.VarChar(30)
  location          String?                           @db.VarChar(30)
  categorySlug      String
  productId         String
  product           FlooringProduct                   @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouseId       String
  warehouse         FlooringWarehouse                 @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  workOrderId       String?
  workOrder         FlooringWorkOrder?                @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  workOrderItemId   String?
  workOrderItem     FlooringWorkOrderItem?            @relation(fields: [workOrderItemId], references: [id], onDelete: SetNull)
  before                 Decimal?                          @db.Decimal(12, 2)
  quantity               Decimal                           @db.Decimal(12, 2)
  coverage               Decimal?                          @db.Decimal(12, 2)
  after                  Decimal?                          @db.Decimal(12, 2)
  stockUnitName          String?
  stockUnitAbbrev        String?
  itemCoverageUnitName   String?
  itemCoverageUnitAbbrev String?
  adjustmentType         FlooringInventoryAdjustmentType   @default(DEDUCTION)
  status                 FlooringInventoryAdjustmentStatus @default(PENDING)
  isFinal                Boolean                           @default(false)
  finalSequence          Int?
  isWaste                Boolean                           @default(false)
  notes                  String?                           @db.VarChar(30)
  createdAt         DateTime                          @default(now())
  updatedAt         DateTime                          @updatedAt

  @@unique([inventoryId, finalSequence])
  @@index([adjustmentNumber])
  @@index([inventoryId])
  @@index([productId])
  @@index([warehouseId])
  @@index([workOrderId])
  @@index([workOrderItemId])
  @@index([workOrderItemId, status])
  @@index([inventoryId, status])
  @@index([inventoryId, isFinal])
  @@index([inventoryId, adjustmentType, isFinal], map: "flooring_inv_adj_hub_filter_idx")
  @@index([status])
  @@index([status, isFinal])
  // Adjustments ledger list view: warehouse-filtered + createdAt/id keyset sort,
  // all-warehouses createdAt/id sort, and inventoryItem substring search
  // (pg_trgm already enabled). inventoryItem is immutable post-create, so the
  // GIN index is insert-only.
  @@index([warehouseId, createdAt, id])
  @@index([createdAt, id])
  @@index([inventoryItem(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_adjustment_inventoryItem_trgm_idx")
  // Per-field identity search on the frozen snapshot columns (the list-view
  // toolbar's 4 search bars ILIKE each column independently). All four are
  // immutable post-create, so these GIN indexes are insert-only — mirrors the
  // flooring_inventory identity trgm indexes.
  @@index([inventoryNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_adjustment_inventoryNumber_trgm_idx")
  @@index([rollNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_adjustment_rollNumber_trgm_idx")
  @@index([dyeLot(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_adjustment_dyeLot_trgm_idx")
  @@index([inventoryNote(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_adjustment_inventoryNote_trgm_idx")
  @@map("flooring_inventory_adjustment")
}

model FlooringJobType {
  id         String              @id @default(uuid())
  name       String              @unique
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  templates  FlooringTemplate[]
  workOrders FlooringWorkOrder[]

  @@index([name])
  @@map("flooring_job_type")
}

model FlooringTemplate {
  id                   String                     @id @default(uuid())
  templateNumber       String                     @unique @default(dbgenerated("('TP-'::text || (nextval('flooring_template_number_seq'::regclass))::text)")) @map("template_number")
  propertyId           String
  property             Property                   @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  managementCompanyId  String?
  managementCompany    FlooringManagementCompany? @relation(fields: [managementCompanyId], references: [id], onDelete: SetNull)
  jobTypeId            String?
  jobType              FlooringJobType?           @relation(fields: [jobTypeId], references: [id], onDelete: SetNull)
  warehouseId          String?
  warehouse            FlooringWarehouse?         @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  unitType             String                     @db.VarChar(40)
  description          String?                    @db.VarChar(120)
  internalNotes        String?                    @db.VarChar(250)
  installerInstructions String?                   @db.VarChar(250)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  items                FlooringTemplateItem[]
  workOrders           FlooringWorkOrder[]

  @@index([templateNumber])
  @@index([propertyId])
  @@index([managementCompanyId])
  @@index([jobTypeId])
  @@index([warehouseId])
  @@index([unitType])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("flooring_template")
}

model FlooringTemplateItem {
  id             String           @id @default(uuid())
  templateId     String
  template       FlooringTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  productId      String
  product        FlooringProduct  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity       Decimal?         @db.Decimal(10, 2)
  sendUnitName   String?
  sendUnitAbbrev String?
  notes          String?          @db.VarChar(30)
  createdAt      DateTime         @default(now())

  @@unique([templateId, productId])
  @@index([templateId])
  @@index([templateId, createdAt])
  @@index([productId])
  @@map("flooring_template_item")
}

model FlooringWarehouse {
  id                  String                             @id @default(uuid())
  number              Int                                @unique
  name                String                             @unique
  streetAddress       String?
  city                String?
  state               String?
  postalCode          String?
  phone               String?
  createdAt           DateTime                           @default(now())
  updatedAt           DateTime                           @updatedAt
  imports             FlooringImportEntry[]
  stagedInventoryRows FlooringImportStagedInventoryRow[]
  inventories          FlooringInventory[]
  inventoryAdjustments FlooringInventoryAdjustment[]
  workOrders           FlooringWorkOrder[]
  templates            FlooringTemplate[]

  @@map("flooring_warehouse")
}

model FlooringWorkOrder {
  id                   String                     @id @default(uuid())
  workOrderNumber      String                     @unique @default(dbgenerated("('WO-'::text || (nextval('flooring_work_order_number_seq'::regclass))::text)")) @map("work_order_number")
  propertyId           String
  property             Property                   @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  templateId           String?
  template             FlooringTemplate?          @relation(fields: [templateId], references: [id], onDelete: SetNull)
  managementCompanyId  String?
  managementCompany    FlooringManagementCompany? @relation(fields: [managementCompanyId], references: [id], onDelete: SetNull)
  jobTypeId            String?
  jobType              FlooringJobType?           @relation(fields: [jobTypeId], references: [id], onDelete: SetNull)
  warehouseId          String?
  warehouse            FlooringWarehouse?         @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  statusId             String?                    @map("status_id")
  status               FlooringWorkOrderStatus?   @relation(fields: [statusId], references: [id], onDelete: SetNull)
  vacancy              FlooringVacancyStatus?
  scheduledFor         DateTime?                  @db.Date
  unitNumber           String?                    @db.VarChar(30)
  unitType             String?                    @db.VarChar(40)
  customAddress        String?                    @db.VarChar(200)
  description          String?                    @db.VarChar(120)
  internalNotes        String?                    @db.VarChar(250)
  installerInstructions String?                   @db.VarChar(250)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  items                FlooringWorkOrderItem[]
  inventoryAdjustments FlooringInventoryAdjustment[]

  @@index([workOrderNumber])
  @@index([statusId])
  @@index([propertyId])
  @@index([templateId])
  @@index([managementCompanyId])
  @@index([jobTypeId])
  @@index([warehouseId])
  @@index([scheduledFor])
  @@index([createdAt])
  @@index([updatedAt])
  // GIN trigram indexes backing the list-view per-column search bars (ILIKE
  // substring). Mirrors the FlooringInventory identity-search indexes.
  @@index([unitType(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_work_order_unitType_trgm_idx")
  @@index([unitNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_work_order_unitNumber_trgm_idx")
  @@index([workOrderNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_work_order_work_order_number_trgm_idx")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_work_order_description_trgm_idx")
  @@map("flooring_work_order")
}

model FlooringWorkOrderStatus {
  id         String              @id @default(uuid())
  slug       String              @unique
  name       String              @unique
  sortOrder  Int                 @default(0)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  workOrders FlooringWorkOrder[]

  @@index([name])
  @@map("flooring_work_order_status")
}

model FlooringWorkOrderItem {
  id                   String                      @id @default(uuid())
  workOrderId          String
  workOrder            FlooringWorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  productId            String
  product              FlooringProduct             @relation(fields: [productId], references: [id], onDelete: Restrict)
  sourceTemplateItemId String?
  quantity             Decimal?                    @db.Decimal(10, 2)
  sendUnitName         String?
  sendUnitAbbrev       String?
  notes                String?                     @db.VarChar(30)
  status               FlooringWorkOrderItemStatus @default(IDLE)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  inventoryAdjustments FlooringInventoryAdjustment[]

  @@unique([workOrderId, productId])
  @@index([workOrderId])
  @@index([workOrderId, createdAt])
  @@index([productId])
  @@index([sourceTemplateItemId])
  @@map("flooring_work_order_item")
}

model QueueOutboxEvent {
  id             String                 @id @default(uuid())
  topic          String
  aggregateType  String
  aggregateId    String
  idempotencyKey String                 @unique
  payloadJson    Json
  status         QueueOutboxEventStatus @default(PENDING)
  availableAt    DateTime               @default(now())
  lockedAt       DateTime?
  lockedBy       String?
  dispatchedAt   DateTime?
  attemptCount   Int                    @default(0)
  lastError      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([status, availableAt])
  @@index([status, availableAt, lockedAt, createdAt])
  @@index([topic, status, availableAt, lockedAt, createdAt])
  @@index([aggregateType, aggregateId])
  @@map("queue_outbox_event")
}

