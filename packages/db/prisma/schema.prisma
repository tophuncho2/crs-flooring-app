  paymentPurpose   FlooringPaymentPurpose? @relation(fields: [paymentPurposeId], references: [id], onDelete: SetNull)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  createdBy    String?
  updatedBy    String?

  @@index([workOrderId])
  @@index([workOrderId, createdAt])
  @@index([entityId])
  @@index([paymentPurposeId])
  @@map("flooring_work_order_planned_payment")
