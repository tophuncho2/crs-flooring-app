// Why an entity is involved in a work order — the reason is separate from the
// entity's own type. Links an Entity (SetNull, like the planned payment) plus a
// free-text `involvementType`. Structure mirrors the work-order child tables
// (Cascade off the work order, actor + timestamp pair). No money/direction — this
// is a plain link+label row; a future second surface to create payments.
model FlooringWorkOrderEntityInvolvement {
  id              String            @id @default(uuid())
  workOrderId     String
  workOrder       FlooringWorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  entityId        String?
  entity          Entity?           @relation(fields: [entityId], references: [id], onDelete: SetNull)
  involvementType String?           @db.VarChar(40)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdBy       String?
  updatedBy       String?

  // Explicit short index names (map:) — the default Prisma names (long table +
  // column) would exceed Postgres' 63-byte identifier limit (the
  // workOrderId+createdAt composite hits 64) and truncate. `fwoei_` =
  // flooring_work_order_entity_involvement. FK constraint names fit as defaults.
  @@index([workOrderId], map: "fwoei_work_order_idx")
  @@index([workOrderId, createdAt], map: "fwoei_work_order_created_at_idx")
  @@index([entityId], map: "fwoei_entity_idx")
  @@map("flooring_work_order_entity_involvement")
}

model QueueOutboxEvent {
  id             String                 @id @default(uuid())
  topic          String
  aggregateType  String
  aggregateId    String
  idempotencyKey String                 @unique
  payloadJson    Json
  status         QueueOutboxEventStatus @default(PENDING)
  availableAt    DateTime               @default(now())
  lockedAt       DateTime?
  lockedBy       String?
  dispatchedAt   DateTime?
  attemptCount   Int                    @default(0)
  lastError      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([status, availableAt])
  @@index([status, availableAt, lockedAt, createdAt])
  @@index([topic, status, availableAt, lockedAt, createdAt])
  @@index([aggregateType, aggregateId])
  @@map("queue_outbox_event")
}

// Shared non-semantic palette colors. User-assigned, meaningless in code — purely
// a visual tag, used across modules (entity types, work orders, …). Kept in sync
// with the domain palette value object (packages/domain/src/shared/palette.ts) and
// the UI class map (apps/web/engines/common/badges/contracts/color-palette.ts).
enum PaletteColor {
  SLATE
  RED
  AMBER
  ORANGE
  LIME
  GREEN
  TEAL
  CYAN
  BLUE
  VIOLET
  PINK
  ROSE
}

// Standalone user-managed lookup row. Mirrors FlooringJobType's canonical ET-
// numbered-record shape (sequence-backed `ET-N` string + generated int for
// exact search + stepper), plus a non-semantic palette color and actor columns.
// Self-contained — NO foreign keys this slice; linking entity types to other
// models is a later step. Duplicate `type` values are allowed (no @unique).
model FlooringEntityType {
  id                  String                  @id @default(uuid())
  entityTypeNumber    String                  @unique @default(dbgenerated("('ET-'::text || (nextval('flooring_entity_type_number_seq'::regclass))::text)")) @map("entity_type_number")
  entityTypeNumberInt Int?                    @default(dbgenerated("(SUBSTRING(entity_type_number FROM 4))::integer"))
  type                String                  @db.VarChar(30)
  color               PaletteColor            @default(SLATE)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  createdBy           String?
  updatedBy           String?
  entities            Entity[]

  @@index([type])
  @@index([entityTypeNumber])
  @@index([entityTypeNumberInt])
  @@index([type(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_entity_type_type_trgm_idx")
  @@map("flooring_entity_type")
}

// Standalone user-managed lookup row. Mirrors FlooringEntityType's canonical
// numbered-record shape (sequence-backed `ROW-N` string + generated int for
// exact search + stepper), plus a non-semantic palette color and actor columns.
// Self-contained — NO foreign keys this slice; linking payment purposes to
// payments (max 1 per payment) and to planned payments are later steps. `name`
// is @unique — one purpose per label.
model FlooringPaymentPurpose {
  id                      String       @id @default(uuid())
  paymentPurposeNumber    String       @unique @default(dbgenerated("('ROW-'::text || (nextval('flooring_payment_purpose_number_seq'::regclass))::text)")) @map("payment_purpose_number")
  paymentPurposeNumberInt Int?         @default(dbgenerated("(SUBSTRING(payment_purpose_number FROM 5))::integer"))
  name                    String       @unique @db.VarChar(30)
  color                   PaletteColor @default(SLATE)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  createdBy               String?
  updatedBy               String?

  templatePlannedPayments  TemplatePlannedPayment[]
  workOrderPlannedPayments FlooringWorkOrderPlannedPayment[]
  payments                 FlooringPayment[]

  @@index([name])
  @@index([paymentPurposeNumber])
  @@index([paymentPurposeNumberInt])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_payment_purpose_name_trgm_idx")
  @@map("flooring_payment_purpose")
}

// Standalone user-managed lookup row for WORK-ORDER PRINT/EXPORT document types
// (e.g. "Picking Ticket", "Work Order"). Mirrors FlooringPaymentPurpose's
// canonical numbered-record shape (sequence-backed `ROW-N` string + generated int
// for exact search + stepper) + a non-semantic palette color + actor columns.
// `printConfig` (jsonb) stores the per-doc-type checkbox default visibilities
// (sections/topFields/adjustmentColumns/materialColumns); it is MERGED over the
// code base-defaults on read (resolvePrintConfig), so newly-added print columns
// flow in naturally without a config backfill. `name` is @unique — it doubles as
// the printed document tag.
model FlooringWorkOrderDocumentType {
  id                             String       @id @default(uuid())
  // Explicit short index/constraint names (map:) — the default Prisma names
  // (table + long `work_order_document_type_number` column) exceed Postgres'
  // 63-byte identifier limit and the UNIQUE + btree would truncate to the SAME
  // name and collide. `fwodt_` = flooring_work_order_document_type.
  workOrderDocumentTypeNumber    String       @unique(map: "fwodt_number_key") @default(dbgenerated("('ROW-'::text || (nextval('flooring_work_order_document_type_number_seq'::regclass))::text)")) @map("work_order_document_type_number")
  workOrderDocumentTypeNumberInt Int?         @default(dbgenerated("(SUBSTRING(work_order_document_type_number FROM 5))::integer"))
  name                           String       @unique(map: "fwodt_name_key") @db.VarChar(40)
  color                          PaletteColor @default(SLATE)
  printConfig                    Json         @default(dbgenerated("'{}'::jsonb"))
  createdAt                      DateTime     @default(now())
  updatedAt                      DateTime     @updatedAt
  createdBy                      String?
  updatedBy                      String?

  printEvents FlooringWorkOrderPrintEvent[]

  @@index([name], map: "fwodt_name_idx")
  @@index([workOrderDocumentTypeNumber], map: "fwodt_number_idx")
  @@index([workOrderDocumentTypeNumberInt], map: "fwodt_number_int_idx")
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "fwodt_name_trgm_idx")
  @@map("flooring_work_order_document_type")
}

// Append-only print/export event log for work orders. One row per Print click,
// keyed by the doc type printed. Counts are aggregates (groupBy documentTypeId).
// Mirrors the WO-child convention (Cascade off the work order + actor + createdAt).
// `documentTypeId` is SetNull (a doc type may be deleted); `documentTypeName` is a
// snapshot of the doc type's name at print time so historical counts survive that
// deletion. Append-only ⇒ no updatedAt, no OCC.
model FlooringWorkOrderPrintEvent {
  id               String                         @id @default(uuid())
  workOrderId      String
  workOrder        FlooringWorkOrder              @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  documentTypeId   String?
  documentType     FlooringWorkOrderDocumentType? @relation(fields: [documentTypeId], references: [id], onDelete: SetNull)
  documentTypeName String                         @db.VarChar(40)
  createdBy        String?
  createdAt        DateTime                       @default(now())

  @@index([workOrderId])
  @@index([workOrderId, documentTypeId])
  @@index([documentTypeId])
  @@map("flooring_work_order_print_event")
}

