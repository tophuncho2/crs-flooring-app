generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRank {
  DEVELOPER
  TIER_1
  TIER_2
  TIER_3
}

model User {
  id                     String                @id @default(uuid())
  name                   String                @default("")
  email                  String                @unique
  emailVerified          Boolean               @default(false)
  image                  String?
  rank                   UserRank              @default(TIER_3)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @default(now()) @updatedAt
  mutationReceipts       AppMutationReceipt[]
  sessions               Session[]
  accounts               Account[]
}

// Better Auth core tables. Field names mirror Better Auth's required schema
// exactly (it accesses them via the camelCase Prisma client). Self-hosted in our
// own Postgres — no external identity store.
model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
}

// Lean invite-only, rank-scoped provisioning. Deliberately NOT Better Auth's
// org/teams plugin — we are a single company, so its team machinery would be
// over-abstraction. An invite pre-sets the new user's rank; Google verifies
// identity on first sign-in.
model UserInvite {
  id         String    @id @default(uuid())
  email      String
  rank       UserRank
  invitedBy  String?
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
}

model AppMutationReceipt {
  id               String    @id @default(uuid())
  scope            String
  userId           String
  idempotencyKey   String
  requestHash      String
  responseStatus   Int?
  responseBodyJson Json?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?
  expiresAt        DateTime
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scope, userId, idempotencyKey])
  @@index([userId])
  @@index([expiresAt])
  @@map("app_mutation_receipt")
}

enum QueueOutboxEventStatus {
  PENDING
  PROCESSING
  DISPATCHED
  EXHAUSTED
}

enum FlooringVacancyStatus {
  VACANT
  OCCUPIED
}

enum FlooringTimeOfDay {
  AM
  PM
}

enum FlooringStagedRowStatus {
  DRAFT
  QUEUED
  IMPORTED
}

enum FlooringInventoryAdjustmentType {
  INCREASE
  DEDUCTION
}

enum FlooringPaymentDirection {
  REVENUE
  EXPENSE
}

enum FlooringConversionOperator {
  DIVIDE
  MULTIPLY
}

enum FlooringConversionFactorMode {
  CONSTANT
  USE_COVERAGE_PER_UNIT
}

model Entity {
  id              String                @id @default(uuid())
  entityNumber    String                @unique @default(dbgenerated("('ENT-'::text || (nextval('entity_number_seq'::regclass))::text)")) @map("entity_number")
  entityNumberInt Int?                  @default(dbgenerated("(SUBSTRING(entity_number FROM 5))::integer"))
  entity          String
  streetAddress   String?
  city            String?
  state           String?
  postalCode      String?
  phone           String?
  email           String?
  color           PaletteColor          @default(SLATE)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  createdBy       String?
  updatedBy       String?
  properties      Property[]
  entityTypeId    String?               @map("entity_type_id")
  entityType      FlooringEntityType?   @relation(fields: [entityTypeId], references: [id], onDelete: SetNull)
  payments        FlooringPayment[]
  products        FlooringProduct[]
  imports         FlooringImportEntry[]
  templatePlannedPayments TemplatePlannedPayment[]
  templateEntityInvolvements TemplateEntityInvolvement[]
  workOrderPlannedPayments FlooringWorkOrderPlannedPayment[]
  workOrderEntityInvolvements FlooringWorkOrderEntityInvolvement[]
  certificates    Certificate[]

  // Sort-column btree backing the work-orders list sort by entity name (2-hop
  // `property.entity.entity`). Plain btree — the sort's `id` tiebreak lives on
  // FlooringWorkOrder, a different table, so a composite here would be meaningless.
  @@index([entity])
  // GIN trigram backing the entity list + picker name search (ILIKE `contains`,
  // case-insensitive). Mirrors every other search bar's identity-search index.
  @@index([entity(ops: raw("gin_trgm_ops"))], type: Gin, map: "entity_entity_trgm_idx")
  // Record-number identity: the unique PREFIX string + the generated int that
  // backs the exact-int `#` search bar and the record-view stepper's neighbor walk.
  @@index([entityNumber])
  @@index([entityNumberInt])
  // List-view sort backing (menu-only multi-column sort). Composite `(col, id)`
  // so the `id` tiebreak resolves in the same scan; the entity-name sort already
  // rides `@@index([entity])`. createdAt/updatedAt are tie-prone under bulk
  // import; `state` is nulls-last (btree serves the ASC-nulls-last case cleanly).
  @@index([createdAt, id])
  @@index([updatedAt, id])
  @@index([state, id])
  // FK backing the entity's single type assignment (nullable, SetNull on type delete).
  @@index([entityTypeId])
  @@map("entity")
}

// A tracked compliance certificate (insurance, license, compliance doc) that
// belongs to an Entity. The expiration "status" (Expired / Expiring Soon / Valid /
// No Expiration) is derived at READ time by the domain `computeCertificateStatus`
// helper — never stored, since a `CURRENT_DATE - expirationDate` diff is not
// immutable and any stored value would be stale the day after write.
model Certificate {
  id             String    @id @default(uuid())
  entityId       String?
  entity         Entity?   @relation(fields: [entityId], references: [id], onDelete: SetNull)
  name           String    @db.VarChar(120)
  expirationDate DateTime? @db.Date
  internalNotes  String?   @db.VarChar(500)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String?
  updatedBy      String?
  files          CertificateFile[]

  @@index([entityId]) // entity filter
  @@index([expirationDate]) // default date sort
  @@index([name]) // name search
  @@index([createdAt, id]) // list sort tiebreak
  @@index([updatedAt, id]) // list sort tiebreak
  @@map("certificate")
}

// A file attached to a certificate (the COI PDF, endorsements, scans, photos).
// Stored in the private S3 bucket under `objectKey`; the row is the durable
// record and `objectKey` its pointer. Cascade-deletes with its parent — the FK
// removes the ROW, and `deleteCertificateUseCase` removes the S3 OBJECT.
model CertificateFile {
  id            String      @id @default(uuid())
  certificateId String
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  objectKey     String      @unique
  fileName      String      @db.VarChar(255)
  contentType   String      @db.VarChar(100)
  sizeBytes     Int
  createdAt     DateTime    @default(now())
  createdBy     String?

  @@index([certificateId]) // parent file list
  @@map("certificate_file")
}

model Property {
  id                  String                     @id @default(uuid())
  propertyNumber      String                     @unique @default(dbgenerated("('PROP-'::text || (nextval('property_hub_number_seq'::regclass))::text)")) @map("property_number")
  propertyNumberInt   Int?                       @default(dbgenerated("(SUBSTRING(property_number FROM 6))::integer"))
  entityId            String?
  entity              Entity?                    @relation(fields: [entityId], references: [id], onDelete: SetNull)
  name                String
  streetAddress       String?
  city                String?
  state               String?
  postalCode          String?
  phone               String?
  email               String?
  instructions        String?
  color               PaletteColor               @default(SLATE)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  createdBy           String?
  updatedBy           String?
  workOrders          FlooringWorkOrder[]
  templates           Template[]

  @@index([entityId])
  @@index([name])
  @@index([propertyNumber])
  @@index([propertyNumberInt])
  @@index([createdAt, id])
  @@index([updatedAt, id])
  @@map("property_hub")
}

model FlooringCategory {
  id                 String                 @id @default(uuid())
  name               String                 @unique
  products                  FlooringProduct[]
  createdAt                 DateTime                                 @default(now())
  updatedAt                 DateTime                                 @updatedAt

  @@map("flooring_category")
}

model FlooringUnitOfMeasure {
  id                         String             @id @default(uuid())
  name                       String             @unique
  abbreviation               String
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  products                   FlooringProduct[]  @relation("FlooringProductUnit")
  coverageProducts           FlooringProduct[]  @relation("FlooringProductCoverageUnit")
  costProducts               FlooringProduct[]  @relation("FlooringProductCostUnit")
  inventories                FlooringInventory[] @relation("FlooringInventoryUnit")
  adjustments                FlooringInventoryAdjustment[] @relation("FlooringAdjustmentUnit")
  indicators                 FlooringInventoryIndicator[] @relation("FlooringIndicatorUnit")
  stagedRows                 FlooringImportStagedInventoryRow[] @relation("FlooringStagedRowUnit")
  stagedFilterRows           FlooringImportStagedInventoryFilterRow[] @relation("FlooringStagedFilterRowUnit")
  plannedProducts            TemplatePlannedProduct[] @relation("TemplatePlannedProductUnit")
  serviceItems               TemplateServiceItem[] @relation("TemplateServiceItemUnit")
  workOrderItems             FlooringWorkOrderItem[] @relation("FlooringWorkOrderItemUnit")
  // Conversion feature: per-row coverage-unit back-relations + formula from/to units.
  inventoryCoverageUnits         FlooringInventory[] @relation("FlooringInventoryCoverageUnit")
  adjustmentCoverageUnits        FlooringInventoryAdjustment[] @relation("FlooringAdjustmentCoverageUnit")
  stagedRowCoverageUnits         FlooringImportStagedInventoryRow[] @relation("FlooringStagedRowCoverageUnit")
  stagedFilterRowCoverageUnits   FlooringImportStagedInventoryFilterRow[] @relation("FlooringStagedFilterRowCoverageUnit")
  conversionFormulasFrom         FlooringConversionFormula[] @relation("FlooringConversionFormulaFromUnit")
  conversionFormulasTo           FlooringConversionFormula[] @relation("FlooringConversionFormulaToUnit")

  @@map("flooring_unit_of_measure")
}

// Read-only conversion lookup (migration-seeded; no CRUD, mirrors UoM/Category).
// Products/rows pick a formula; `convertedBalance` + the target unit are DERIVED
// on-read (never stored). The formula stays dumb: it names how to convert, not
// per-product numbers. `factorMode=CONSTANT` uses `constantFactor` (e.g. carpet
// ×1.333); `USE_COVERAGE_PER_UNIT` uses the consuming row's own `coveragePerUnit`
// (e.g. planks ÷ sq-ft-per-box). `fromUnitId` guards the source: the derived value
// blanks when a row's own unit doesn't match. Migration CHECK enforces
// `factorMode=CONSTANT ⇒ constantFactor NOT NULL`.
model FlooringConversionFormula {
  id             String                       @id @default(uuid())
  name           String                       @unique
  fromUnitId     String
  fromUnit       FlooringUnitOfMeasure        @relation("FlooringConversionFormulaFromUnit", fields: [fromUnitId], references: [id], onDelete: Restrict)
  toUnitId       String
  toUnit         FlooringUnitOfMeasure        @relation("FlooringConversionFormulaToUnit", fields: [toUnitId], references: [id], onDelete: Restrict)
  operator       FlooringConversionOperator
  factorMode     FlooringConversionFactorMode
  constantFactor Decimal?                     @db.Decimal(12, 4)
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  products         FlooringProduct[]
  inventories      FlooringInventory[]
  adjustments      FlooringInventoryAdjustment[]
  stagedRows       FlooringImportStagedInventoryRow[]
  stagedFilterRows FlooringImportStagedInventoryFilterRow[]

  @@index([fromUnitId])
  @@index([toUnitId])
  @@map("flooring_conversion_formula")
}

model FlooringProduct {
  id                               String                             @id @default(uuid())
  productNumber                    String                             @unique @default(dbgenerated("('PROD-'::text || (nextval('flooring_product_number_seq'::regclass))::text)")) @map("product_number")
  productNumberInt                 Int?                               @default(dbgenerated("(SUBSTRING(product_number FROM 6))::integer"))
  name                             String                             @default("")
  categoryId                       String
  category                         FlooringCategory                   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  unitId                           String
  unit                             FlooringUnitOfMeasure              @relation("FlooringProductUnit", fields: [unitId], references: [id], onDelete: Restrict)
  entityId                         String?
  entity                           Entity?                            @relation(fields: [entityId], references: [id], onDelete: SetNull)
  style                            String?
  color                            String?
  // Non-semantic palette tag (user-assigned visual color). Distinct from the
  // free-text physical `color` above — never overload that. Edit-only: only the
  // record-view edit form sets it; create/import/worker/seed fall to SLATE.
  paletteColor                     PaletteColor                       @default(SLATE)
  coveragePerUnit                  Decimal?                           @db.Decimal(12, 4)
  // Coverage basis unit (pairs with coveragePerUnit). Seeded onto inventory/
  // adjustment/staged rows on product-select; editable there.
  coverageUnitId                   String?
  coverageUnit                     FlooringUnitOfMeasure?             @relation("FlooringProductCoverageUnit", fields: [coverageUnitId], references: [id], onDelete: Restrict)
  // Conversion feature: the formula this product converts its stock with. Picked
  // in the product form; seeded onto inventory/adjustment/staged rows on select.
  conversionFormulaId              String?
  conversionFormula                FlooringConversionFormula?         @relation(fields: [conversionFormulaId], references: [id], onDelete: Restrict)
  // Money standard: Decimal(12,2), normalized at every write boundary. NULL = unset.
  cost                             Decimal?                           @db.Decimal(12, 2)
  // The unit `cost` is priced per (e.g. $/sq ft). Independent of `unitId`; editable.
  costUnitId                       String?
  costUnit                         FlooringUnitOfMeasure?             @relation("FlooringProductCostUnit", fields: [costUnitId], references: [id], onDelete: Restrict)
  // Money standard: Decimal(12,2). The customer-facing sell price per unit. Seeded
  // onto a template's planned product when this product is picked; editable there.
  // Bare money — no unit FK (priced per the row's own unit). NULL = unset.
  unitPrice                        Decimal?                           @db.Decimal(12, 2)
  productNamingAddon               String?                            @db.VarChar(80)
  // Archive flag (mirrors FlooringInventory.isArchived). Default-hidden from the
  // products list unless the Archived filter is chosen, and excluded from every
  // product picker's options so an archived product can't be freshly selected.
  isArchived                       Boolean                            @default(false)
  createdAt                        DateTime                           @default(now())
  updatedAt                        DateTime                           @updatedAt
  createdBy                        String?
  updatedBy                        String?
  plannedProducts                        TemplatePlannedProduct[]
  workOrderItems                         FlooringWorkOrderItem[]
  inventories                            FlooringInventory[]
  inventoryAdjustments                   FlooringInventoryAdjustment[]
  inventoryIndicators                    FlooringInventoryIndicator[]
  FlooringImportStagedInventoryRow       FlooringImportStagedInventoryRow[]
  FlooringImportStagedInventoryFilterRow FlooringImportStagedInventoryFilterRow[]

  @@index([entityId])
  @@index([unitId])
  @@index([coverageUnitId])
  @@index([costUnitId])
  @@index([conversionFormulaId])
  @@index([name])
  @@index([productNumber])
  @@index([productNumberInt])
  @@index([isArchived])
  @@index([style(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_product_style_trgm_idx")
  @@index([color(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_product_color_trgm_idx")
  @@index([productNamingAddon(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_product_productNamingAddon_trgm_idx")
  // Btree indexes backing the list-view Sort tool (menu-only). Composite
  // `(col, id)` throughout — the house canonical: one uniform-direction btree
  // serves ASC/DESC via backward scan and carries the `id` tiebreak. style/color
  // are nullable free-text (the GIN-trgm indexes above serve ILIKE search, NOT
  // ORDER BY). `category` sort rides FlooringCategory.name @unique.
  @@index([createdAt, id])
  @@index([updatedAt, id])
  @@index([style, id])
  @@index([color, id])
  @@map("flooring_product")
}

model FlooringInventory {
  id                     String               @id @default(uuid())
  inventoryNumber        String               @unique @default(dbgenerated("('INV-'::text || (nextval('flooring_inventory_number_seq'::regclass))::text)")) @map("inventory_number")
  inventoryNumberInt     Int?                 @default(dbgenerated("(SUBSTRING(inventory_number FROM 5))::integer"))
  importEntryId          String?
  importEntry            FlooringImportEntry? @relation(fields: [importEntryId], references: [id], onDelete: Restrict)
  productId              String
  product                FlooringProduct      @relation(fields: [productId], references: [id], onDelete: Restrict)
  // Canonical unit FK (UoM epic 2B). Create-only, immutable after. Seeded from
  // the product on manual create (overridable) or from the staged row at
  // materialize. The snapshot strings below are NOT a read fallback (display
  // derives from the `unit` join) — retained only to keep the promote
  // migration/backfill scripts safe; dropped post-promote (UoM 2D).
  unitId                 String
  unit                   FlooringUnitOfMeasure @relation("FlooringInventoryUnit", fields: [unitId], references: [id], onDelete: Restrict)
  // Conversion feature (editable post-create, seeded from the product on create).
  // convertedBalance + the target unit derive ON-READ from `conversionFormula`;
  // nothing converted is stored. coverageUnit/coveragePerUnit are the coverage basis.
  coverageUnitId         String?
  coverageUnit           FlooringUnitOfMeasure? @relation("FlooringInventoryCoverageUnit", fields: [coverageUnitId], references: [id], onDelete: Restrict)
  coveragePerUnit        Decimal?             @db.Decimal(12, 4)
  conversionFormulaId    String?
  conversionFormula      FlooringConversionFormula? @relation(fields: [conversionFormulaId], references: [id], onDelete: Restrict)
  rollPrefix             String               @default("ROLL#")
  rollNumber             String?              @db.VarChar(30)
  dyeLot                 String?              @db.VarChar(30)
  note                   String?              @db.VarChar(30)
  internalNotes          String?              @db.VarChar(250)
  // Non-semantic palette tag (shared PaletteColor enum). Metadata only — never
  // participates in stock/netDeducted/ledger math. Editable post-create.
  color                  PaletteColor         @default(SLATE)
  warehouseId            String
  warehouse              FlooringWarehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  location               String?              @db.VarChar(30)
  startingStock          Decimal              @db.Decimal(12, 2)
  cost                   Decimal?             @db.Decimal(12, 2)
  freight                Decimal?             @db.Decimal(12, 2)
  netDeducted            Decimal              @default(0) @db.Decimal(12, 2)
  // When the stock balance (netDeducted → derived stockQuantity) last changed.
  // Stamped ONLY by the adjustment-recompute (`recomputeAndPersistNetDeducted`),
  // so — unlike `updatedAt`, which bumps on any field edit — this means
  // specifically "stock balance last changed". Nullable: null until the row's
  // first adjustment (a freshly created row's balance is its startingStock).
  balanceLastChangedAt   DateTime?
  // STORED generated stock quantity = max(0, startingStock - netDeducted),
  // mirroring the pure domain helper `computeInventoryBalance`. Sort-only key
  // for the list view's Quantity column; the displayed value still flows from
  // that domain helper in `normalizeInventoryRow` (surfaced as `stockBalance`).
  stockQuantity          Decimal?             @default(dbgenerated("GREATEST((\"startingStock\" - \"netDeducted\"), (0)::numeric)")) @db.Decimal(12, 2)
  isArchived             Boolean              @default(false)
  inventoryAdjustments   FlooringInventoryAdjustment[]
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  createdBy              String?
  updatedBy              String?

  @@index([inventoryNumber])
  @@index([inventoryNumberInt])
  @@index([importEntryId])
  @@index([productId])
  @@index([unitId])
  @@index([coverageUnitId])
  @@index([conversionFormulaId])
  @@index([warehouseId])
  @@index([isArchived])
  @@index([stockQuantity, id])
  @@index([productId, createdAt, rollNumber, id])
  // Sort-column btree indexes for the menu-only inventory list sort. Composite
  // `(col, id)` so the `id` tiebreak resolves in the same scan — createdAt/updatedAt
  // are tie-prone under bulk import/worker-materialize. `(createdAt, id)` backs the
  // default list ordering (createdAt DESC, id DESC). location is only ever sorted
  // with warehouse filtered first, so lead the composite with warehouseId.
  @@index([createdAt, id])
  @@index([warehouseId, location, id])
  @@index([updatedAt, id])
  // inventoryNumber search is an exact match on `inventoryNumberInt` (btree), so
  // the number column no longer needs a trigram index.
  @@index([rollNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_rollNumber_trgm_idx")
  @@index([dyeLot(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_dyeLot_trgm_idx")
  @@index([note(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_note_trgm_idx")
  @@index([location(ops: raw("gin_trgm_ops"))], type: Gin, map: "flooring_inventory_location_trgm_idx")
  @@map("flooring_inventory")
}

model FlooringInventoryIndicator {
  id                 String                @id @default(uuid())
  indicatorNumber    String                @unique @default(dbgenerated("('IND-'::text || (nextval('flooring_inventory_indicator_number_seq'::regclass))::text)")) @map("indicator_number")
  indicatorNumberInt Int?                  @default(dbgenerated("(SUBSTRING(indicator_number FROM 5))::integer"))
  // Low-stock tracker scoped to ONE (product, warehouse, unit) triple — a product
  // holds stock across many warehouses/UoMs, so the tracker must be a child table.
  // One indicator per triple (@@unique below). The colored status (OK / Low) is
  // DERIVED on read (live SUM(stockQuantity) for the triple vs lowStockThreshold),
  // never stored; the future notification worker reads the same derivation.
  productId          String
  product            FlooringProduct       @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId        String
  warehouse          FlooringWarehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  unitId             String
  unit               FlooringUnitOfMeasure @relation("FlooringIndicatorUnit", fields: [unitId], references: [id], onDelete: Restrict)
  // Money standard: Decimal(12,2), normalized at every write boundary. NULL = no
  // threshold set → neutral status.
  lowStockThreshold  Decimal?              @db.Decimal(12, 2)
  internalNotes      String?               @db.VarChar(250)
  // Mute a tracker without deleting it (also the future-worker eval gate).
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  createdBy          String?
  updatedBy          String?

  @@unique([productId, warehouseId, unitId])
  @@index([indicatorNumber])
  @@index([indicatorNumberInt])
  @@index([warehouseId])
  @@index([unitId])
  @@index([isActive])
  @@index([createdAt, id])
  @@index([updatedAt, id])
  @@map("flooring_inventory_indicator")
}

model FlooringImportStagedInventoryRow {
  id            String                                 @id @default(uuid())
  importEntryId String
  importEntry   FlooringImportEntry                    @relation(fields: [importEntryId], references: [id], onDelete: Restrict)
  productId     String
  product       FlooringProduct                        @relation(fields: [productId], references: [id], onDelete: Restrict)
  // Editable unit FK (UoM epic 2B) — seeded from the product, editable while
  // DRAFT; the worker materializes it forward onto the inventory row. Nullable
  // (a half-drafted row needn't carry a unit); the importability gate blocks
  // QUEUED/import when null so the worker never nulls inventory's NOT-NULL unit.
  unitId        String?
  unit          FlooringUnitOfMeasure?                 @relation("FlooringStagedRowUnit", fields: [unitId], references: [id], onDelete: Restrict)
  // Conversion feature — seeded from the product, editable; materialized forward.
  coverageUnitId      String?
  coverageUnit        FlooringUnitOfMeasure?           @relation("FlooringStagedRowCoverageUnit", fields: [coverageUnitId], references: [id], onDelete: Restrict)
  coveragePerUnit     Decimal?                         @db.Decimal(12, 4)
  conversionFormulaId String?
  conversionFormula   FlooringConversionFormula?       @relation(fields: [conversionFormulaId], references: [id], onDelete: Restrict)
  rollPrefix    String                                 @default("ROLL#")
  rollNumber    String?                                @db.VarChar(30)
  dyeLot        String?                                @db.VarChar(30)
  location        String?                                @db.VarChar(30)
  startingStock   Decimal                                @db.Decimal(12, 2)
  cost            Decimal?                               @db.Decimal(12, 2)
  freight         Decimal?                               @db.Decimal(12, 2)
  status          FlooringStagedRowStatus                @default(DRAFT)
  note            String?                                @db.VarChar(30)
  createdAt       DateTime                               @default(now())
  updatedAt       DateTime                               @updatedAt

  @@index([importEntryId])
  @@index([productId])
  @@index([unitId])
  @@index([coverageUnitId])
  @@index([conversionFormulaId])
  @@index([importEntryId, status])
  @@map("flooring_import_staged_inventory_row")
}

model FlooringImportStagedInventoryFilterRow {
