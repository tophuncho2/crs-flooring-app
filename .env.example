# Shared database owner: packages/db
DATABASE_URL=

# Web auth owner: apps/web
# Optional for general local boot. Required when using auth/session flows.
NEXTAUTH_SECRET=replace-with-a-secret-at-least-16-characters-long
NEXTAUTH_URL=http://localhost:3000

# Web observability owner: apps/web
# NEXT_PUBLIC_SENTRY_DSN enables Sentry event delivery from the browser and server.
# SENTRY_AUTH_TOKEN, SENTRY_ORG, and SENTRY_PROJECT are only required when uploading
# source maps during production builds.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Web storage owner: apps/web
# Optional for general local boot. Required when using S3-backed file flows.
AWS_ACCESS_KEY_ID=replace-me
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=https://your-bucket-endpoint.example.com
AWS_S3_BUCKET_NAME=
AWS_SECRET_ACCESS_KEY=replace-me

# Web rate-limit infra
# RATE_LIMIT_REDIS_URL is optional locally. In staging and main it should be
# configured for the web service.
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_PREFIX=

# Queue infra for relay + worker
# QUEUE_REDIS_URL is optional locally until async services are started. In staging
# and main it should be configured for relay and worker.
QUEUE_REDIS_URL=

# Temporary migration fallback only. New config should prefer RATE_LIMIT_REDIS_URL
# and QUEUE_REDIS_URL.
REDIS_URL=

# Worker tunables
# materialize-import-batch handler. Defaults are conservative (concurrency=1,
# lock=60s). Bump concurrency only if multiple imports queue simultaneously
# and DB row-lock contention isn't a concern.
MATERIALIZE_WORKER_CONCURRENCY=
MATERIALIZE_WORKER_LOCK_DURATION_MS=
# work-order file generation handler. Defaults: concurrency=1, lock=180s.
WORK_ORDER_FILE_GENERATION_WORKER_CONCURRENCY=
WORK_ORDER_FILE_GENERATION_WORKER_LOCK_DURATION_MS=

# Relay tunables (outbox dispatcher)
# Defaults: batch=20, poll=2s, claim TTL=30s, max attempts=5.
RELAY_BATCH_SIZE=
RELAY_POLL_INTERVAL_MS=
RELAY_CLAIM_TTL_MS=
RELAY_MAX_ATTEMPTS=

# Bull Board (relay UI for queue inspection)
# BULL_BOARD_ENABLED defaults to true in development, false otherwise.
# Username + password are required when enabled outside development.
BULL_BOARD_ENABLED=
BULL_BOARD_HOST=
BULL_BOARD_PORT=
BULL_BOARD_BASE_PATH=
BULL_BOARD_USERNAME=
BULL_BOARD_PASSWORD=

# Optional DB seed operators used by packages/db scripts.
# Configure both EMAIL + PASSWORD per slot. Empty slots are skipped.
# Password must be at least 12 characters.
SEEDED_ADMIN_EMAIL=
SEEDED_ADMIN_PASSWORD=
SEEDED_BUILDER_EMAIL=
SEEDED_BUILDER_PASSWORD=
SEEDED_OWNER_1_EMAIL=
SEEDED_OWNER_1_PASSWORD=
SEEDED_OWNER_2_EMAIL=
SEEDED_OWNER_2_PASSWORD=
SEEDED_OWNER_3_EMAIL=
SEEDED_OWNER_3_PASSWORD=
SEEDED_OWNER_4_EMAIL=
SEEDED_OWNER_4_PASSWORD=
SEEDED_OWNER_5_EMAIL=
SEEDED_OWNER_5_PASSWORD=
SEEDED_OWNER_6_EMAIL=
SEEDED_OWNER_6_PASSWORD=
SEEDED_OWNER_7_EMAIL=
SEEDED_OWNER_7_PASSWORD=
SEEDED_OWNER_8_EMAIL=
SEEDED_OWNER_8_PASSWORD=
SEEDED_OWNER_9_EMAIL=
SEEDED_OWNER_9_PASSWORD=
SEEDED_OWNER_10_EMAIL=
SEEDED_OWNER_10_PASSWORD=
