# Shared database owner: packages/db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/builderswebapp

# Web auth owner: apps/web
# Optional for general local boot. Required when using auth/session flows.
NEXTAUTH_SECRET=replace-with-a-secret-at-least-16-characters-long
NEXTAUTH_URL=http://localhost:3000

# Web storage owner: apps/web
# Optional for general local boot. Required when using S3-backed file flows.
AWS_ACCESS_KEY_ID=replace-me
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=https://your-bucket-endpoint.example.com
AWS_S3_BUCKET_NAME=builders-app
AWS_SECRET_ACCESS_KEY=replace-me

# Shared rate limiting / queue infra
# REDIS_URL is optional locally. In staging and production it should be configured
# for the web service, and for the worker once queue execution is enabled.
REDIS_URL=
RATE_LIMIT_PREFIX=builderswebapp:local

# Optional DB seed operators used by packages/db scripts
SEEDED_ADMIN_EMAIL=
SEEDED_ADMIN_PASSWORD=
SEEDED_BUILDER_EMAIL=
SEEDED_BUILDER_PASSWORD=
